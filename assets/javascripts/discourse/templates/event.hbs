<div class="event-detail-container">
  <div class="event-detail-header">
    <h1>{{this.model.title}}</h1>
    <span class="event-status event-status--{{this.model.status}}">
      {{this.model.status}}
    </span>
  </div>

  <div class="event-detail-meta">
    <div class="event-detail-meta-item">
      <strong>Organisation:</strong> {{this.model.organisation.name}}
    </div>
    <div class="event-detail-meta-item">
      <strong>Date:</strong> {{this.model.formatted_date}}
    </div>
    {{#if this.model.location}}
      <div class="event-detail-meta-item">
        <strong>Location:</strong> {{this.model.location}}
      </div>
    {{/if}}
    {{#if this.model.google_maps_url}}
      <div class="event-detail-meta-item">
        <a href={{this.model.google_maps_url}} target="_blank" rel="noopener">
          📍 View on Google Maps
        </a>
      </div>
    {{/if}}
  </div>

  {{#if this.model.description}}
    <div class="event-description-box cooked">
      {{{this.model.description_cooked}}}
    </div>
  {{/if}}


  {{#if (eq this.model.status "cancelled")}}
    <div class="event-cancelled-banner">⚠️ This event has been cancelled.</div>
  {{else if this.bookingClosed}}
    <div class="event-closed-banner">⏰ Booking has closed for this event.</div>
  {{/if}}

  {{#unless this.bookingDisabled}}
  <div class="event-detail-classes">
    <h2>Classes</h2>
    <div class="event-classes-grid">
      {{#each this.model.classes as |cls|}}
        <div class="event-class-card {{if (eq cls.status "sold_out") "sold-out"}}">
          <div class="event-class-name">{{cls.name}}</div>
          <div class="event-class-spaces">
            {{cls.spaces_remaining}} / {{cls.capacity}} spaces
          </div>
          {{#if (eq cls.status "sold_out")}}
            <button
              class="btn btn-small btn-default"
              {{on "click" (fn this.joinWaitlist cls.id)}}
            >
              📋 Join Waitlist
            </button>
          {{else}}
            <input
              type="checkbox"
              id="class-{{cls.id}}"
              value={{cls.id}}
              {{on "change" (fn this.toggleClass cls.id)}}
            />
            <label for="class-{{cls.id}}">Select</label>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </div>

  {{#if this.model.max_classes_per_booking}}
    <p class="field-help">⚠️ Maximum {{this.model.max_classes_per_booking}} class(es) per booking.</p>
  {{/if}}

  {{#if this.model.pricing}}
    <div class="event-detail-pricing">
      <h2>Pricing</h2>
      {{#if (eq this.model.pricing.rule_type "tiered")}}
        <p>First class: £{{this.model.pricing.first_class_price}}</p>
        <p>Additional classes: £{{this.model.pricing.subsequent_class_price}} each</p>
      {{else}}
        <p>£{{this.model.pricing.flat_price}} per class</p>
      {{/if}}

      {{#if this.selectedClasses.length}}
        <div class="event-booking-summary">
          <strong>Selected: {{this.selectedClasses.length}} classes</strong>
          <strong>Total: £{{this.calculatedTotal}}</strong>
        </div>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Family Booking Section --}}
  {{#if this.model.family_members.length}}
    <div class="event-family-booking">
      <button
        class="btn btn-default family-toggle"
        {{on "click" this.toggleFamilySection}}
      >
        {{if this.familyExpanded "▼" "▶"}} Book Family Members
      </button>

      {{#if this.familyExpanded}}
        <div class="family-members-list">
          {{#each this.model.family_members as |member|}}
            <div class="family-member-card">
              <h3>{{member.username}}</h3>
              <div class="event-classes-grid">
                {{#each this.model.classes as |cls|}}
                  <div class="event-class-card {{if (eq cls.status "sold_out") "sold-out"}}">
                    <div class="event-class-name">{{cls.name}}</div>
                    <div class="event-class-spaces">
                      {{cls.spaces_remaining}} / {{cls.capacity}} spaces
                    </div>
                    {{#if (eq cls.status "sold_out")}}
                      <span class="field-help">Sold out</span>
                    {{else}}
                      <input
                        type="checkbox"
                        id="family-{{member.user_id}}-class-{{cls.id}}"
                        {{on "change" (fn this.toggleFamilyClass member.user_id cls.id)}}
                      />
                      <label for="family-{{member.user_id}}-class-{{cls.id}}">Select</label>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Updated booking summary --}}
  {{#if this.model.pricing}}
    {{#if this.hasFamilySelections}}
      <div class="event-booking-summary family-summary">
        <strong>Combined Total (you + family): {{this.totalClassCount}} classes</strong>
        <strong>Total: &pound;{{this.calculatedTotal}}</strong>
      </div>
    {{/if}}
  {{/if}}

  <div class="event-detail-actions">
    {{#if (eq this.model.status "draft")}}
      <button class="btn btn-warning" {{on "click" this.publishEvent}}>
        📢 Publish Event
      </button>
    {{/if}}
    {{#if this.currentUser}}
      <button
        class="btn btn-primary"
        disabled={{eq this.selectedClasses.length 0}}
        {{on "click" this.bookEvent}}
      >
        {{if this.isBooking "Processing..." "Book Now"}}
      </button>
      {{#if this.model.is_admin}}
        <LinkTo @route="event-manage" @model={{this.model.id}} class="btn btn-default">
          ⚙️ Manage Event
        </LinkTo>
      {{/if}}
    {{else}}
      <p>Please <a href="/login">log in</a> to book this event.</p>
    {{/if}}


    <div class="calendar-dropdown-wrapper">
      <button class="btn btn-default" type="button" {{on "click" this.toggleCalendarDropdown}}>
        📅 Add to Calendar
      </button>
      {{#if this.showCalendarDropdown}}
        <div class="calendar-dropdown">
          <a href="#" class="calendar-dropdown-item" {{on "click" this.downloadICS}}>
            📅 Download ICS (Apple/Outlook)
          </a>
          <a href={{this.googleCalendarUrl}} class="calendar-dropdown-item" target="_blank" rel="noopener">
            📅 Google Calendar
          </a>
          <a href={{this.outlookCalendarUrl}} class="calendar-dropdown-item" target="_blank" rel="noopener">
            📅 Outlook.com
          </a>
        </div>
      {{/if}}
    </div>

  </div>
  {{/unless}}


  {{!-- Who's Coming Section (collapsible) --}}
  {{#if this.totalEntrantCount}}
    <div class="event-whos-coming">
      <button class="whos-coming-toggle" type="button" {{on "click" this.toggleWhosComingSection}}>
        <span class="whos-coming-chevron">{{if this.isWhosComingExpanded "▼" "▶"}}</span>
        <h2>👥 Who's Coming? ({{this.totalEntrantCount}} entries)</h2>
      </button>

      {{#if this.isWhosComingExpanded}}
        {{#each this.model.public_entrants as |cls|}}
          {{#if cls.entrants.length}}
            <div class="entrants-class">
              <h3>{{cls.name}}</h3>
              <table class="entrants-table entrants-table--public">
                <thead>
                  <tr>
                    <th class="avatar-col"></th>
                    <th>Username</th>
                    <th>Manufacturer</th>
                    <th>Model</th>
                    <th>Transponder</th>
                    <th>BRCA No.</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each cls.entrants as |entrant|}}
                    <tr class="entrant-row entrant-row--{{entrant.status}}">
                      <td class="avatar-col"><a data-user-card={{entrant.username}}><img src="{{entrant.avatar_template}}" class="entrant-avatar" alt="" /></a></td>
                      <td>{{entrant.username}}</td>
                      <td>{{entrant.manufacturer_name}}</td>
                      <td>{{entrant.model_name}}</td>
                      <td class="transponder-number">{{entrant.transponder}}</td>
                      <td>{{entrant.brca_number}}</td>
                      <td>
                        <span class="booking-status booking-status--{{entrant.status}}">
                          {{entrant.status}}
                        </span>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{/if}}
        {{/each}}
      {{/if}}
    </div>
  {{/if}}




  {{#if this.model.topic_url}}
    <div class="event-discussion-link">
      <a href={{this.model.topic_url}} class="btn btn-primary">
        💬 View Discussion & Comments
      </a>
    </div>
  {{/if}}


  {{!-- Car Selection Modal --}}
  {{#if this.showCarSelection}}
    <div class="car-selection-overlay">
      <div class="car-selection-modal">
        <h2>Select Cars</h2>
        <p class="field-help">Select which car to enter for each class. Your garage is used for all family members.</p>

        <h3>Your Classes</h3>
        {{#each this.eligibleCars as |cls|}}
          <div class="car-selection-class">
            <h4>{{cls.class_name}}</h4>
            {{#if cls.eligible_cars.length}}
              <select {{on "change" (fn this.selectCar cls.class_id)}}>
                <option value="">Select car...</option>
                {{#each cls.eligible_cars as |car|}}
                  <option value={{car.id}}>
                    {{car.friendly_name}} — {{car.driveline}} — {{car.transponder_number}}{{#if car.owner_username}} ({{car.owner_username}}){{/if}}
                  </option>
                {{/each}}
              </select>
            {{else}}
              <div class="no-eligible-cars">
                No eligible cars in your garage for this class.
                <LinkTo @route="my-garage" class="btn btn-small btn-default">
                  Add a car
                </LinkTo>
              </div>
            {{/if}}
          </div>
        {{/each}}

        {{#if this.familyEligibleCars}}
          {{#each this.familyEligibleCars as |entry|}}
            <h3>{{entry.username}}</h3>
            {{#each entry.classes as |cls|}}
              <div class="car-selection-class">
                <h4>{{cls.class_name}}</h4>
                {{#if cls.eligible_cars.length}}
                  <select {{on "change" (fn this.selectFamilyCar entry.user_id cls.class_id)}}>
                    <option value="">Select car...</option>
                    {{#each cls.eligible_cars as |car|}}
                      <option value={{car.id}}>
                        {{car.friendly_name}} — {{car.driveline}} — {{car.transponder_number}}{{#if car.owner_username}} ({{car.owner_username}}){{/if}}
                      </option>
                    {{/each}}
                  </select>
                {{else}}
                  <div class="no-eligible-cars">
                    No eligible cars in your garage for this class.
                  </div>
                {{/if}}
              </div>
            {{/each}}
          {{/each}}
        {{/if}}

        <div class="car-selection-actions">
          <button
            class="btn btn-primary"
            disabled={{not this.allCarsSelected}}
            {{on "click" this.confirmBooking}}
          >
            {{if this.isBooking "Processing..." "Confirm & Pay"}}
          </button>
          <button class="btn btn-default" {{on "click" this.cancelCarSelection}}>
            Cancel
          </button>
        </div>
      </div>
    </div>
  {{/if}}
</div>

<div class="des-admin-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="organisations" class="btn btn-default">🏢 Organisations</LinkTo>
    <LinkTo @route="des-admin" class="btn btn-primary">⚙️ Admin</LinkTo>
  </div>

  <h1>Event System Admin</h1>

  <div class="des-admin-tabs">
    <button class="btn {{if (eq this.activeTab 'organisations') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabOrganisations}}>
      🏢 Organisations
      {{#if this.model.pending_organisations.length}}
        <span class="pending-badge">{{this.model.pending_organisations.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'manufacturers') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabManufacturers}}>
      🏭 Manufacturers
      {{#if this.model.pending_manufacturers.length}}
        <span class="pending-badge">{{this.model.pending_manufacturers.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'models') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabModels}}>
      🚗 Car Models
      {{#if this.model.pending_models.length}}
        <span class="pending-badge">{{this.model.pending_models.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'rules') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabRules}}>
      📋 Class Rules
    </button>
  </div>

  {{!-- ORGANISATIONS TAB --}}
  {{#if (eq this.activeTab "organisations")}}
    <div class="des-admin-section">
      <h2>
        Pending Organisations
        {{#if this.model.pending_organisations.length}}
          <span class="pending-badge">{{this.model.pending_organisations.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_organisations.length}}
        {{#each this.model.pending_organisations as |org|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{org.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 {{org.created_by}}</span>
                {{#if org.contact_email}}<span>✉️ {{org.contact_email}}</span>{{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success" {{on "click" (fn this.approveOrganisation org)}}>✅ Approve</button>
              <button class="btn btn-danger" {{on "click" (fn this.rejectOrganisation org)}}>❌ Reject</button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No pending organisations 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <h2>Approved Organisations ({{this.model.approved_organisations.length}})</h2>
      {{#each this.model.approved_organisations as |org|}}
        <div class="admin-org-card admin-org-card--approved">
          <div class="admin-org-info">
            <h3>{{org.name}}</h3>
            <div class="admin-org-meta">
              <span>💰 Surcharge: {{org.surcharge_percentage}}%</span>
              {{#if org.contact_email}}<span>✉️ {{org.contact_email}}</span>{{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>

    {{#if this.model.rejected_organisations.length}}
      <div class="des-admin-section">
        <h2>Rejected Organisations ({{this.model.rejected_organisations.length}})</h2>
        {{#each this.model.rejected_organisations as |org|}}
          <div class="admin-org-card admin-org-card--rejected">
            <div class="admin-org-info">
              <h3>{{org.name}}</h3>
              {{#if org.rejection_reason}}
                <p class="rejection-reason">Reason: {{org.rejection_reason}}</p>
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{!-- MANUFACTURERS TAB --}}
  {{#if (eq this.activeTab "manufacturers")}}
    <div class="des-admin-section">
      <h2>
        Pending Manufacturers
        {{#if this.model.pending_manufacturers.length}}
          <span class="pending-badge">{{this.model.pending_manufacturers.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_manufacturers.length}}
        {{#each this.model.pending_manufacturers as |manufacturer|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{manufacturer.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 Suggested by: {{manufacturer.created_by}}</span>
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success" {{on "click" (fn this.approveManufacturer manufacturer)}}>✅ Approve</button>
              <button class="btn btn-danger" {{on "click" (fn this.rejectManufacturer manufacturer)}}>❌ Reject</button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No pending manufacturers 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <h2>Approved Manufacturers ({{this.model.approved_manufacturers.length}})</h2>
      {{#if this.model.approved_manufacturers.length}}
        <div class="approved-manufacturers-list">
          {{#each this.model.approved_manufacturers as |manufacturer|}}
            <div class="admin-org-card">
              {{#if (eq this.editingManufacturerId manufacturer.id)}}
                <div class="admin-org-info" style="flex:1;">
                  <input
                    type="text"
                    value={{this.editingManufacturerName}}
                    {{on "input" this.updateEditingManufacturerName}}
                    class="manufacturer-edit-input"
                  />
                </div>
                <div class="admin-org-actions">
                  <button class="btn btn-small btn-primary" {{on "click" this.saveManufacturer}}>Save</button>
                  <button class="btn btn-small btn-default" {{on "click" this.cancelEditManufacturer}}>Cancel</button>
                </div>
              {{else}}
                <div class="admin-org-info">
                  <strong>{{manufacturer.name}}</strong>
                </div>
                <div class="admin-org-actions">
                  <button class="btn btn-small btn-default" {{on "click" (fn this.startEditManufacturer manufacturer)}}>✏️ Edit</button>
                  <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteManufacturer manufacturer)}}>🗑 Delete</button>
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="no-pending">No approved manufacturers yet.</p>
      {{/if}}
    </div>
  {{/if}}


  {{!-- CAR MODELS TAB --}}
  {{#if (eq this.activeTab "models")}}
    <div class="des-admin-section">
      <h2>
        Pending Car Models
        {{#if this.model.pending_models.length}}
          <span class="pending-badge">{{this.model.pending_models.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_models.length}}
        <p class="field-help">When approving, you will be asked to enter the year of first manufacture.</p>
        {{#each this.model.pending_models as |model|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{model.manufacturer}} {{model.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 Suggested by: {{model.created_by}}</span>
                {{#if model.driveline}}<span>⚙️ {{model.driveline}}</span>{{/if}}
                {{#if model.chassis_type}}<span>🚗 {{model.chassis_type}}</span>{{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success" {{on "click" (fn this.approveModel model)}}>✅ Approve</button>
              <button class="btn btn-danger" {{on "click" (fn this.rejectModel model)}}>❌ Reject</button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No pending car models 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <div class="section-header">
        <h2>Approved Car Models ({{this.model.approved_models.length}})</h2>
        <button class="btn btn-primary btn-small" {{on "click" this.toggleAddModelForm}}>
          {{if this.showAddModelForm "✕ Cancel" "+ Add Model"}}
        </button>
      </div>

      {{#if this.showAddModelForm}}
        <div class="add-model-form">
          <div class="org-form-row">
            <div class="org-form-field">
              <label>Manufacturer *</label>
              <select {{on "change" (fn this.updateNewModel "manufacturer_id")}}>
                <option value="">Select manufacturer...</option>
                {{#each this.model.approved_manufacturers as |mfr|}}
                  <option value={{mfr.id}}>{{mfr.name}}</option>
                {{/each}}
              </select>
            </div>
            <div class="org-form-field">
              <label>Model Name *</label>
              <input type="text" placeholder="e.g. B7.1" {{on "input" (fn this.updateNewModel "name")}} />
            </div>
          </div>
          <div class="org-form-row">
            <div class="org-form-field">
              <label>Year Released</label>
              <input type="number" placeholder="e.g. 2024" min="1970" max="2030" {{on "input" (fn this.updateNewModel "year_released")}} />
            </div>
            <div class="org-form-field">
              <label>Driveline</label>
              <select {{on "change" (fn this.updateNewModel "driveline")}}>
                <option value="">Select...</option>
                {{#each this.drivelines as |d|}}
                  <option value={{d}}>{{d}}</option>
                {{/each}}
              </select>
            </div>
            <div class="org-form-field">
              <label>Chassis Type</label>
              <select {{on "change" (fn this.updateNewModel "chassis_type")}}>
                <option value="">Select...</option>
                {{#each this.chassisTypes as |c|}}
                  <option value={{c}}>{{c}}</option>
                {{/each}}
              </select>
            </div>
          </div>
          <button class="btn btn-primary" {{on "click" this.createModel}}>
            ✅ Add Model
          </button>
        </div>
      {{/if}}

      <p class="field-help">Edit year, driveline or chassis type for any approved model.</p>
      {{#each this.model.approved_models_by_manufacturer as |mfr|}}
        <div class="models-manufacturer-group">
          <h3 class="models-manufacturer-heading">🏭 {{mfr.manufacturer}}</h3>
          <div class="models-grid">
            {{#each mfr.models as |model|}}
              <div class="model-card {{if (eq this.editingModelId model.id) 'model-card--editing'}}">
                {{#if (eq this.editingModelId model.id)}}
                  <div class="model-edit-form">
                    <div class="org-form-field">
                      <label>Name</label>
                      <input type="text" value={{this.editingModel.name}} {{on "input" (fn this.updateEditField "name")}} />
                    </div>
                    <div class="org-form-field">
                      <label>Year</label>
                      <input type="number" value={{this.editingModel.year_released}} min="1970" max="2030" {{on "input" (fn this.updateEditField "year_released")}} />
                    </div>
                    <div class="org-form-field">
                      <label>Driveline</label>
                      <select {{on "change" (fn this.updateEditField "driveline")}}>
                        <option value="">Select...</option>
                        {{#each this.drivelines as |d|}}
                          <option value={{d}} selected={{eq d this.editingModel.driveline}}>{{d}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="org-form-field">
                      <label>Chassis Type</label>
                      <select {{on "change" (fn this.updateEditField "chassis_type")}}>
                        <option value="">Select...</option>
                        {{#each this.chassisTypes as |c|}}
                          <option value={{c}} selected={{eq c this.editingModel.chassis_type}}>{{c}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="model-card-actions">
                      <button class="btn btn-primary btn-small" {{on "click" this.saveModel}}>💾 Save</button>
                      <button class="btn btn-default btn-small" {{on "click" this.cancelEdit}}>✕ Cancel</button>
                    </div>
                  </div>
                {{else}}
                  <div class="model-card-header">
                    <strong>{{model.name}}</strong>
                    {{#if model.chassis_type}}
                      <span class="driveline-badge">{{model.chassis_type}}</span>
                    {{else}}
                      <span class="pending-tag">⚠️ No chassis</span>
                    {{/if}}
                  </div>
                  <div class="model-card-meta">
                    {{#if model.year_released}}<span>📅 {{model.year_released}}</span>{{/if}}
                    {{#if model.driveline}}<span class="driveline-badge">{{model.driveline}}</span>{{/if}}
                  </div>
                  <div class="model-card-actions">
                    <button class="btn btn-default btn-small" {{on "click" (fn this.editModel model)}}>
                      ✏️ Edit
                    </button>
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- CLASS RULES TAB --}}
  {{#if (eq this.activeTab "rules")}}
    <div class="des-admin-section">
      <h2>Class Compatibility Rules</h2>
      <p class="field-help">These rules apply globally to all organisations. They define which cars are eligible for each class type.</p>

      <div class="rule-form">
        <h3>Add Global Rule</h3>
        <div class="form-row">
          <label>Class Type</label>
          <select id="new-rule-class-type">
            <option value="">Select class type...</option>
            {{#each this.model.class_types as |ct|}}
              <option value={{ct.id}}>{{ct.name}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-row">
          <label>Rule Type</label>
          <select id="new-rule-type">
            <option value="driveline">Driveline</option>
            <option value="chassis">Chassis Type</option>
          </select>
        </div>
        <div class="form-row">
          <label>Allowed Values (comma separated)</label>
          <input type="text" id="new-rule-value" placeholder="e.g. 2WD,4WD" />
        </div>
        <button class="btn btn-primary" {{on "click" this.addGlobalRule}}>+ Add Rule</button>
      </div>

      {{#each this.model.global_rules as |rule|}}
        <div class="class-rules-group">
          <div class="class-rule-row">
            <span class="rule-class">{{rule.class_type_name}}</span>
            <span class="rule-type">{{rule.rule_type}}</span>
            <span class="rule-value">{{rule.rule_value}}</span>
            <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteGlobalRule rule.id)}}>🗑</button>
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}



</div>

<div class="des-admin-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="organisations" class="btn btn-default">🏢 Organisations</LinkTo>
    <LinkTo @route="des-admin" class="btn btn-primary">⚙️ Admin</LinkTo>
  </div>

  <h1>Event System Admin</h1>

  <div class="des-admin-tabs">
    <button class="btn {{if (eq this.activeTab 'organisations') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabOrganisations}}>
      🏢 Organisations
      {{#if this.model.pending_organisations.length}}
        <span class="pending-badge">{{this.model.pending_organisations.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'manufacturers') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabManufacturers}}>
      🏭 Manufacturers
      {{#if this.model.pending_manufacturers.length}}
        <span class="pending-badge">{{this.model.pending_manufacturers.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'models') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabModels}}>
      🚗 Car Models
      {{#if this.model.pending_models.length}}
        <span class="pending-badge">{{this.model.pending_models.length}}</span>
      {{/if}}
    </button>
    <button class="btn {{if (eq this.activeTab 'rules') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabRules}}>
      📋 Class Rules
    </button>
    <button class="btn {{if (eq this.activeTab 'venues') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabVenues}}>
      📍 Venues
    </button>
    <button class="btn {{if (eq this.activeTab 'cleanup') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabCleanup}}>
      🔧 Cleanup
    </button>
    <button class="btn {{if (eq this.activeTab 'scales') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabScales}}>
      📏 Scales
    </button>
    <button class="btn {{if (eq this.activeTab 'chassis_types') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabChassisTypes}}>
      🚗 Chassis Types
    </button>
    <button class="btn {{if (eq this.activeTab 'payouts') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabPayouts}}>
      💰 Payouts
    </button>
    <button class="btn {{if (eq this.activeTab 'suggestions') 'btn-primary' 'btn-default'}}" {{on "click" this.setTabSuggestions}}>
      💡 Venue Suggestions
      {{#if this.pendingSuggestionsCount}}
        <span class="pending-badge">{{this.pendingSuggestionsCount}}</span>
      {{/if}}
    </button>
  </div>

  {{!-- ORGANISATIONS TAB --}}
  {{#if (eq this.activeTab "organisations")}}
    <div class="des-admin-section">
      <h2>
        Pending Organisations
        {{#if this.model.pending_organisations.length}}
          <span class="pending-badge">{{this.model.pending_organisations.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_organisations.length}}
        {{#each this.model.pending_organisations as |org|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{org.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 {{org.created_by}}</span>
                {{#if org.contact_email}}<span>✉️ {{org.contact_email}}</span>{{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success" {{on "click" (fn this.approveOrganisation org)}}>✅ Approve</button>
              <button class="btn btn-danger" {{on "click" (fn this.rejectOrganisation org)}}>❌ Reject</button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No pending organisations 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <h2>Approved Organisations ({{this.model.approved_organisations.length}})</h2>
      {{#each this.model.approved_organisations as |org|}}
        <div class="admin-org-card admin-org-card--approved">
          <div class="admin-org-info">
            <h3>{{org.name}}</h3>
            <div class="admin-org-meta">
              <span>💰 Surcharge: {{org.surcharge_percentage}}%</span>
              {{#if org.contact_email}}<span>✉️ {{org.contact_email}}</span>{{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>

    {{#if this.model.rejected_organisations.length}}
      <div class="des-admin-section">
        <h2>Rejected Organisations ({{this.model.rejected_organisations.length}})</h2>
        {{#each this.model.rejected_organisations as |org|}}
          <div class="admin-org-card admin-org-card--rejected">
            <div class="admin-org-info">
              <h3>{{org.name}}</h3>
              {{#if org.rejection_reason}}
                <p class="rejection-reason">Reason: {{org.rejection_reason}}</p>
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{!-- MANUFACTURERS TAB --}}
  {{#if (eq this.activeTab "manufacturers")}}
    <div class="des-admin-section">
      <h2>
        Pending Manufacturers
        {{#if this.model.pending_manufacturers.length}}
          <span class="pending-badge">{{this.model.pending_manufacturers.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_manufacturers.length}}
        {{#each this.model.pending_manufacturers as |manufacturer|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{manufacturer.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 Suggested by: {{manufacturer.created_by}}</span>
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success" {{on "click" (fn this.approveManufacturer manufacturer)}}>✅ Approve</button>
              <button class="btn btn-danger" {{on "click" (fn this.rejectManufacturer manufacturer)}}>❌ Reject</button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No pending manufacturers 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <h2>Approved Manufacturers ({{this.model.approved_manufacturers.length}})</h2>
      {{#if this.model.approved_manufacturers.length}}
        <div class="approved-manufacturers-list">
          {{#each this.model.approved_manufacturers as |manufacturer|}}
            <div class="admin-org-card">
              {{#if (eq this.editingManufacturerId manufacturer.id)}}
                <div class="admin-org-info" style="flex:1;">
                  <input
                    type="text"
                    value={{this.editingManufacturerName}}
                    {{on "input" this.updateEditingManufacturerName}}
                    class="manufacturer-edit-input"
                  />
                </div>
                <div class="admin-org-actions">
                  <button class="btn btn-small btn-primary" {{on "click" this.saveManufacturer}}>Save</button>
                  <button class="btn btn-small btn-default" {{on "click" this.cancelEditManufacturer}}>Cancel</button>
                </div>
              {{else}}
                <div class="admin-org-info">
                  <strong>{{manufacturer.name}}</strong>
                </div>
                <div class="admin-org-actions">
                  <button class="btn btn-small btn-default" {{on "click" (fn this.startEditManufacturer manufacturer)}}>✏️ Edit</button>
                  <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteManufacturer manufacturer)}}>🗑 Delete</button>
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="no-pending">No approved manufacturers yet.</p>
      {{/if}}
    </div>
  {{/if}}


  {{!-- CAR MODELS TAB --}}
  {{#if (eq this.activeTab "models")}}
    <div class="des-admin-section">
      <h2>
        Pending Car Models
        {{#if this.model.pending_models.length}}
          <span class="pending-badge">{{this.model.pending_models.length}}</span>
        {{/if}}
      </h2>
      {{#if this.model.pending_models.length}}
        {{#each this.model.pending_models as |model|}}
          <div class="admin-org-card admin-org-card--pending">
            <div class="admin-org-info">
              <h3>{{model.manufacturer}} {{model.name}}</h3>
              <div class="admin-org-meta">
                <span>👤 Suggested by: {{model.created_by}}</span>
                {{#if model.driveline}}<span>⚙️ {{model.driveline}}</span>{{/if}}
                {{#if model.scale}}<span>📏 {{model.scale}}</span>{{/if}}
                {{#if model.chassis_type}}<span>🚗 {{model.chassis_type}}</span>{{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-success btn-small" {{on "click" (fn this.startApproveModel model)}}>✅ Approve</button>
              <button class="btn btn-danger btn-small" {{on "click" (fn this.rejectModel model)}}>❌ Reject</button>
            </div>
          </div>
          {{#if (eq this.approvingModelId model.id)}}
            <div class="add-model-form" style="margin-top: 8px;">
              <h4>Approve: {{model.manufacturer}} {{model.name}}</h4>
              <div class="org-form-row">
                <div class="org-form-field">
                  <label>Year of First Manufacture</label>
                  <input type="number" placeholder="e.g. 2023" value={{this.approveModelForm.year_released}} {{on "input" (fn this.updateApproveField "year_released")}} />
                </div>
                <div class="org-form-field">
                  <label>Driveline</label>
                  <select {{on "change" (fn this.updateApproveField "driveline")}}>
                    <option value="">Select...</option>
                    {{#each this.drivelines as |d|}}
                      <option value={{d}} selected={{eq this.approveModelForm.driveline d}}>{{d}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="org-form-field">
                  <label>Scale</label>
                  <select {{on "change" (fn this.updateApproveField "scale")}}>
                    <option value="">Select...</option>
                    {{#each this.scales as |s|}}
                      <option value={{s}} selected={{eq this.approveModelForm.scale s}}>{{s}}</option>
                    {{/each}}
                  </select>
                </div>
                <div class="org-form-field">
                  <label>Chassis Type</label>
                  <select {{on "change" (fn this.updateApproveField "chassis_type")}}>
                    <option value="">Select...</option>
                    {{#each this.chassisTypes as |c|}}
                      <option value={{c}} selected={{eq this.approveModelForm.chassis_type c}}>{{c}}</option>
                    {{/each}}
                  </select>
                </div>
              </div>
              <div style="display:flex;gap:8px;margin-top:8px;">
                <button class="btn btn-primary" {{on "click" this.confirmApproveModel}}>✅ Confirm Approval</button>
                <button class="btn btn-default" {{on "click" this.cancelApproveModel}}>✕ Cancel</button>
              </div>
            </div>
          {{/if}}
        {{/each}}
      {{else}}
        <p class="no-pending">No pending car models 🎉</p>
      {{/if}}
    </div>

    <div class="des-admin-section">
      <div class="section-header">
        <h2>Approved Car Models ({{this.model.approved_models.length}})</h2>
        <button class="btn btn-primary btn-small" {{on "click" this.toggleAddModelForm}}>
          {{if this.showAddModelForm "✕ Cancel" "+ Add Model"}}
        </button>
      </div>

      {{#if this.showAddModelForm}}
        <div class="add-model-form">
          <div class="org-form-row">
            <div class="org-form-field">
              <label>Manufacturer *</label>
              <select {{on "change" (fn this.updateNewModel "manufacturer_id")}}>
                <option value="">Select manufacturer...</option>
                {{#each this.model.approved_manufacturers as |mfr|}}
                  <option value={{mfr.id}}>{{mfr.name}}</option>
                {{/each}}
              </select>
            </div>
            <div class="org-form-field">
              <label>Model Name *</label>
              <input type="text" placeholder="e.g. B7.1" {{on "input" (fn this.updateNewModel "name")}} />
            </div>
          </div>
          <div class="org-form-row">
            <div class="org-form-field">
              <label>Year Released</label>
              <input type="number" placeholder="e.g. 2024" min="1970" max="2030" {{on "input" (fn this.updateNewModel "year_released")}} />
            </div>
            <div class="org-form-field">
              <label>Driveline</label>
              <select {{on "change" (fn this.updateNewModel "driveline")}}>
                <option value="">Select...</option>
                {{#each this.drivelines as |d|}}
                  <option value={{d}}>{{d}}</option>
                {{/each}}
              </select>
            </div>
            <div class="org-form-field">
              <label>Scale</label>
              <select {{on "change" (fn this.updateNewModel "scale")}}>
                <option value="">Select...</option>
                {{#each this.scales as |s|}}
                  <option value={{s}}>{{s}}</option>
                {{/each}}
              </select>
            </div>
            <div class="org-form-field">
              <label>Chassis Type</label>
              <select {{on "change" (fn this.updateNewModel "chassis_type")}}>
                <option value="">Select...</option>
                {{#each this.chassisTypes as |c|}}
                  <option value={{c}}>{{c}}</option>
                {{/each}}
              </select>
            </div>
          </div>
          <button class="btn btn-primary" {{on "click" this.createModel}}>
            ✅ Add Model
          </button>
        </div>
      {{/if}}

      <p class="field-help">Edit year, driveline or chassis type for any approved model.</p>
      {{#each this.model.approved_models_by_manufacturer as |mfr|}}
        <div class="models-manufacturer-group">
          <h3 class="models-manufacturer-heading">🏭 {{mfr.manufacturer}}</h3>
          <div class="models-grid">
            {{#each mfr.models as |model|}}
              <div class="model-card {{if (eq this.editingModelId model.id) 'model-card--editing'}}">
                {{#if (eq this.editingModelId model.id)}}
                  <div class="model-edit-form">
                    <div class="org-form-field">
                      <label>Manufacturer</label>
                      <select {{on "change" (fn this.updateEditField "manufacturer_id")}}>
                        {{#each this.model.approved_manufacturers as |mfr|}}
                          <option value={{mfr.id}} selected={{eq (concat mfr.id "") (concat this.editingModel.manufacturer_id "")}}>{{mfr.name}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="org-form-field">
                      <label>Name</label>
                      <input type="text" value={{this.editingModel.name}} {{on "input" (fn this.updateEditField "name")}} />
                    </div>
                    <div class="org-form-field">
                      <label>Year</label>
                      <input type="number" value={{this.editingModel.year_released}} min="1970" max="2030" {{on "input" (fn this.updateEditField "year_released")}} />
                    </div>
                    <div class="org-form-field">
                      <label>Driveline</label>
                      <select {{on "change" (fn this.updateEditField "driveline")}}>
                        <option value="">Select...</option>
                        {{#each this.drivelines as |d|}}
                          <option value={{d}} selected={{eq d this.editingModel.driveline}}>{{d}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="org-form-field">
                      <label>Scale</label>
                      <select {{on "change" (fn this.updateEditField "scale")}}>
                        <option value="">Select...</option>
                        {{#each this.scales as |s|}}
                          <option value={{s}} selected={{eq s this.editingModel.scale}}>{{s}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="org-form-field">
                      <label>Chassis Type</label>
                      <select {{on "change" (fn this.updateEditField "chassis_type")}}>
                        <option value="">Select...</option>
                        {{#each this.chassisTypes as |c|}}
                          <option value={{c}} selected={{eq c this.editingModel.chassis_type}}>{{c}}</option>
                        {{/each}}
                      </select>
                    </div>
                    <div class="model-card-actions">
                      <button class="btn btn-primary btn-small" {{on "click" this.saveModel}}>💾 Save</button>
                      <button class="btn btn-default btn-small" {{on "click" this.cancelEdit}}>✕ Cancel</button>
                    </div>
                  </div>
                {{else}}
                  <div class="model-card-header">
                    <strong>{{model.name}}</strong>
                    {{#if model.scale}}<span class="driveline-badge">📏 {{model.scale}}</span>{{/if}}
                    {{#if model.chassis_type}}
                      <span class="driveline-badge">🚗 {{model.chassis_type}}</span>
                    {{else}}
                      <span class="pending-tag">⚠️ No chassis</span>
                    {{/if}}
                  </div>
                  <div class="model-card-meta">
                    {{#if model.year_released}}<span>📅 {{model.year_released}}</span>{{/if}}
                    {{#if model.driveline}}<span class="driveline-badge">{{model.driveline}}</span>{{/if}}
                  </div>
                  <div class="model-card-actions">
                    <button class="btn btn-default btn-small" {{on "click" (fn this.editModel model)}}>
                      ✏️ Edit
                    </button>
                    <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteModel model)}}>
                      🗑 Delete
                    </button>
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- CLASS RULES TAB --}}
  {{#if (eq this.activeTab "rules")}}
    <div class="des-admin-section">
      <h2>Class Compatibility Rules</h2>
      <p class="field-help">Define global class types with eligibility rules. All fields are optional — leave blank to allow any value.</p>

      <div class="section-header">
        <button class="btn btn-primary btn-small" {{on "click" this.toggleAddClassTypeForm}}>
          {{if this.showAddClassTypeForm "✕ Cancel" "+ Add Class Type"}}
        </button>
      </div>

      {{#if this.showAddClassTypeForm}}
        <div class="add-model-form">
          <h3>New Class Type</h3>
          <DesClassTypeForm
            @manufacturers={{this.model.approved_manufacturers}}
            @models={{this.model.approved_models}}
            @onSave={{this.createClassType}}
            @onCancel={{this.toggleAddClassTypeForm}}
            @saveLabel="✅ Create Class Type"
          />
        </div>
      {{/if}}

      <h3 style="margin-top: 16px;">Global Class Types</h3>
      {{#each this.model.global_class_types as |ct|}}
        <div class="admin-org-card">
          <div class="admin-org-info">
            <strong>{{ct.name}}</strong>
            <div class="admin-org-meta">
              {{#if ct.track_environment}}<span>{{if (eq ct.track_environment "onroad") "🛣️ On-Road" "🌿 Off-Road"}}</span>{{/if}}
              {{#if ct.scale}}<span>📏 {{ct.scale}}</span>{{/if}}
              {{#if ct.chassis_types.length}}<span>🚗 {{ct.chassis_types}}</span>{{/if}}
              {{#if ct.drivelines.length}}<span>⚙️ {{ct.drivelines}}</span>{{/if}}
              {{#if ct.min_year}}<span>📅 From {{ct.min_year}}</span>{{/if}}
              {{#if ct.max_year}}<span>📅 Until {{ct.max_year}}</span>{{/if}}
              {{#if ct.manufacturer}}<span>🏭 {{ct.manufacturer}}</span>{{/if}}
              {{#if ct.min_age}}<span>👤 Age {{ct.min_age}}+</span>{{/if}}
              {{#if ct.max_age}}<span>👤 Age ≤{{ct.max_age}}</span>{{/if}}
            </div>
          </div>
          <div class="admin-org-actions">
            <button class="btn btn-default btn-small" {{on "click" (fn this.startEditClassType ct)}}>✏️ Edit</button>
            <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteClassType ct)}}>🗑 Delete</button>
          </div>
        </div>
        {{#if (eq this.editingClassTypeId ct.id)}}
          <DesClassTypeForm
            @classType={{ct}}
            @manufacturers={{this.model.approved_manufacturers}}
            @models={{this.model.approved_models}}
            @onSave={{this.saveEditClassType}}
            @onCancel={{this.cancelEditClassType}}
            @saveLabel="💾 Save Changes"
          />
        {{/if}}
      {{/each}}

      {{#if this.model.org_class_type_groups.length}}
        <h3 style="margin-top: 32px;">Organisation Class Types</h3>
        <p class="field-help">Class types created by each organisation for their own events.</p>
        {{#each this.model.org_class_type_groups as |group|}}
          <div class="admin-org-card" style="margin-bottom: 8px;">
            <div class="admin-org-info" style="cursor: pointer;" role="button" {{on "click" (fn this.toggleOrgClassGroup group.organisation_id)}}>
              <strong>{{group.organisation_name}}</strong>
              <span class="field-help" style="margin-left: 8px;">{{group.class_types.length}} class type(s)</span>
              <span style="float: right;">{{if (includes this.expandedOrgGroups group.organisation_id) "▼" "▶"}}</span>
            </div>
          </div>
          {{#if (includes this.expandedOrgGroups group.organisation_id)}}
            {{#each group.class_types as |ct|}}
              <div class="admin-org-card" style="margin-left: 24px; margin-bottom: 8px;">
                <div class="admin-org-info">
                  <strong>{{ct.name}}</strong>
                  <div class="admin-org-meta">
                    {{#if ct.track_environment}}<span>{{if (eq ct.track_environment "onroad") "🛣️ On-Road" "🌿 Off-Road"}}</span>{{/if}}
                    {{#if ct.scale}}<span>📏 {{ct.scale}}</span>{{/if}}
                    {{#if ct.chassis_types.length}}<span>🚗 {{ct.chassis_types}}</span>{{/if}}
                    {{#if ct.drivelines.length}}<span>⚙️ {{ct.drivelines}}</span>{{/if}}
                    {{#if ct.min_year}}<span>📅 From {{ct.min_year}}</span>{{/if}}
                    {{#if ct.max_year}}<span>📅 Until {{ct.max_year}}</span>{{/if}}
                    {{#if ct.manufacturer}}<span>🏭 {{ct.manufacturer}}</span>{{/if}}
                    {{#if ct.min_age}}<span>👤 Age {{ct.min_age}}+</span>{{/if}}
                    {{#if ct.max_age}}<span>👤 Age ≤{{ct.max_age}}</span>{{/if}}
                  </div>
                </div>
                <div class="admin-org-actions">
                  <button class="btn btn-default btn-small" {{on "click" (fn this.startEditClassType ct)}}>✏️ Edit</button>
                  <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteOrgClassType ct group.organisation_id)}}>🗑 Delete</button>
                </div>
              </div>
              {{#if (eq this.editingClassTypeId ct.id)}}
                <DesClassTypeForm
                  @classType={{ct}}
                  @manufacturers={{this.model.approved_manufacturers}}
                  @models={{this.model.approved_models}}
                  @onSave={{this.saveEditClassType}}
                  @onCancel={{this.cancelEditClassType}}
                  @saveLabel="💾 Save Changes"
                />
              {{/if}}
            {{/each}}
          {{/if}}
        {{/each}}
      {{/if}}
    </div>
  {{/if}}




  {{!-- CLEANUP TAB --}}
  {{#if (eq this.activeTab "cleanup")}}
    <div class="des-admin-section">
      <h2>🔧 Orphaned Cars</h2>
      <p class="field-help">Cars with missing or rejected manufacturers/models.</p>

      {{#if this.orphanedCars.length}}
        {{#each this.orphanedCars as |car|}}
          <div class="admin-org-card">
            {{#if (eq this.editingOrphanCarId car.id)}}
              <div class="orphan-edit-form" style="width:100%;">
                <strong>{{car.friendly_name}}</strong> <span class="field-help">({{car.username}})</span>
                <div class="org-form-row" style="margin-top:8px;">
                  <div class="org-form-field">
                    <label>Manufacturer</label>
                    <select {{on "change" this.updateOrphanMfr}}>
                      <option value="">Select...</option>
                      {{#each this.model.approved_manufacturers as |mfr|}}
                        <option value={{mfr.id}} selected={{eq (concat mfr.id "") (concat this.editingOrphanMfr "")}}>{{mfr.name}}</option>
                      {{/each}}
                    </select>
                  </div>
                  <div class="org-form-field">
                    <label>Model</label>
                    <select {{on "change" this.updateOrphanModel}}>
                      <option value="">Select...</option>
                      {{#each this.orphanModels as |m|}}
                        <option value={{m.id}} selected={{eq (concat m.id "") (concat this.editingOrphanModel "")}}>{{m.name}}</option>
                      {{/each}}
                    </select>
                  </div>
                </div>
                <div style="display:flex;gap:6px;margin-top:8px;">
                  <button class="btn btn-primary btn-small" {{on "click" (fn this.saveOrphanCar car)}}>Save</button>
                  <button class="btn btn-default btn-small" {{on "click" this.cancelEditOrphanCar}}>Cancel</button>
                </div>
              </div>
            {{else}}
              <div class="admin-org-info">
                <strong>{{car.friendly_name}}</strong>
                <div class="admin-org-meta">
                  <span>👤 {{car.username}}</span>
                  <span>🏭 {{if car.manufacturer_name car.manufacturer_name "⚠️ No manufacturer"}}</span>
                  <span>🚗 {{if car.model_name car.model_name "⚠️ No model"}}
                    {{#if car.model_status}}
                      <span class="booking-status booking-status--{{car.model_status}}">{{car.model_status}}</span>
                    {{/if}}
                  </span>
                </div>
              </div>
              <div class="admin-org-actions">
                <button class="btn btn-default btn-small" {{on "click" (fn this.startEditOrphanCar car)}}>✏️ Fix</button>
                <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteOrphanCar car)}}>🗑 Delete</button>
              </div>
            {{/if}}
          </div>
        {{/each}}
      {{else}}
        <p class="no-pending">No orphaned cars found 🎉</p>
      {{/if}}
    </div>
  {{/if}}


  {{!-- VENUES TAB --}}
  {{#if (eq this.activeTab "venues")}}
    <div class="des-admin-section">
      <div class="section-header" style="margin-bottom:16px;display:flex;gap:8px;align-items:center;">
        <button class="btn btn-default btn-small" {{on "click" this.geocodeAllVenues}} disabled={{this.isGeocoding}}>
          {{if this.isGeocoding "⏳ Geocoding..." "📍 Fetch Missing Coordinates"}}
        </button>
        {{#if this.geocodeResult}}
          <span class="field-help">{{this.geocodeResult}}</span>
        {{/if}}
        <button class="btn btn-primary btn-small" {{on "click" this.toggleAddVenueForm}}>
          {{if this.showAddVenueForm "✕ Cancel" "+ Add Venue"}}
        </button>
      </div>

      {{#if this.showAddVenueForm}}
        <div class="add-model-form">
          <h3>New Venue</h3>
          <DesVenueForm
            @onSave={{this.createAdminVenue}}
            @onCancel={{this.toggleAddVenueForm}}
            @saveLabel="✅ Create Venue"
          />
        </div>
      {{/if}}

      <h2>Pending Venues</h2>
      {{#if this.adminVenues.length}}
        {{#each this.adminVenues as |venue|}}
          {{#if (eq venue.status "pending")}}
            <div class="admin-org-card admin-org-card--pending">
              <div class="admin-org-info">
                <h3>{{venue.name}}</h3>
                <div class="admin-org-meta">
                  <span>📍 {{venue.address}}</span>
                  {{#if venue.organisation_name}}<span>🏢 {{venue.organisation_name}}</span>{{/if}}
                  <span class="booking-status booking-status--pending">pending</span>
                </div>
              </div>
              <div class="admin-org-actions">
                <button class="btn btn-success" {{on "click" (fn this.approveVenue venue)}}>✅ Approve</button>
                <button class="btn btn-danger" {{on "click" (fn this.deleteVenue venue)}}>❌ Delete</button>
              </div>
            </div>
          {{/if}}
        {{/each}}
      {{/if}}

      <h2>Approved Venues</h2>
      {{#each this.adminVenues as |venue|}}
        {{#if (eq venue.status "approved")}}
          <div class="admin-org-card">
            <div class="admin-org-info">
              <strong>{{venue.name}}</strong>
              <div class="admin-org-meta">
                {{#if venue.address}}<span>📍 {{venue.address}}</span>{{/if}}
                {{#each venue.tracks as |track|}}
                  {{#if track.surface}}<span>{{track.surface}}</span>{{/if}}
                  {{#if track.environment}}<span>{{track.environment}}</span>{{/if}}
                {{/each}}
                {{#if venue.is_shared}}<span>🤝 Shared</span>{{/if}}
                {{#if venue.has_permanent_toilets}}<span>🚻</span>{{/if}}
                {{#if venue.has_portaloos}}<span>🚽</span>{{/if}}
                {{#if venue.has_cafe}}<span>☕</span>{{/if}}
                {{#if venue.has_bar}}<span>🍺</span>{{/if}}
                {{#if venue.has_showers}}<span>🚿</span>{{/if}}
                {{#if venue.has_power_supply}}<span>⚡</span>{{/if}}
                {{#if venue.has_water_supply}}<span>💧</span>{{/if}}
                {{#if venue.has_camping}}<span>⛺</span>{{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <button class="btn btn-small btn-default" {{on "click" (fn this.startEditVenue venue)}}>✏️ Edit</button>
              <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteVenue venue)}}>🗑 Delete</button>
            </div>
          </div>
          {{#if (eq this.editingVenueId venue.id)}}
            <DesVenueForm
              @venue={{venue}}
              @onSave={{this.saveEditVenue}}
              @onCancel={{this.cancelEditVenue}}
              @saveLabel="💾 Save Changes"
            />
          {{/if}}
        {{/if}}
      {{/each}}
    </div>
  {{/if}}

  {{!-- SCALES TAB --}}
  {{#if (eq this.activeTab "scales")}}
    <div class="des-admin-section">
      <h2>📏 Scales</h2>
      <div class="admin-list">
        {{#each this.scalesList as |scale|}}
          <div class="admin-list-item">
            <span>{{scale.name}}</span>
            <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteScale scale)}}>🗑️ Delete</button>
          </div>
        {{/each}}
      </div>
      <div class="admin-add-form">
        <input type="text" placeholder="New scale (e.g. 1/5)" value={{this.newScaleName}} {{on "input" (fn this.updateAdminField "newScaleName")}} />
        <button class="btn btn-primary" {{on "click" this.addScale}}>➕ Add Scale</button>
      </div>
    </div>
  {{/if}}

  {{!-- CHASSIS TYPES TAB --}}
  {{#if (eq this.activeTab "chassis_types")}}
    <div class="des-admin-section">
      <h2>🚗 Chassis Types</h2>
      <div class="admin-list">
        {{#each this.chassisTypesList as |ct|}}
          <div class="admin-list-item">
            <span>{{ct.name}}</span>
            <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteChassisType ct)}}>🗑️ Delete</button>
          </div>
        {{/each}}
      </div>
      <div class="admin-add-form">
        <input type="text" placeholder="New chassis type (e.g. Crawler)" value={{this.newChassisTypeName}} {{on "input" (fn this.updateAdminField "newChassisTypeName")}} />
        <button class="btn btn-primary" {{on "click" this.addChassisType}}>➕ Add Chassis Type</button>
      </div>
    </div>
  {{/if}}

  {{!-- PAYOUTS TAB --}}
  {{#if (eq this.activeTab "payouts")}}
    <div class="des-admin-section">
      <div style="display:flex;gap:8px;margin-bottom:20px;align-items:center;flex-wrap:wrap;">
        <span style="font-weight:600;">Period:</span>
        <button class="btn btn-small {{if (eq this.payoutPeriod 'all') 'btn-primary' 'btn-default'}}" {{on "click" (fn this.setPayoutPeriod "all")}}>All Time</button>
        <button class="btn btn-small {{if (eq this.payoutPeriod 'year') 'btn-primary' 'btn-default'}}" {{on "click" (fn this.setPayoutPeriod "year")}}>This Year</button>
        <button class="btn btn-small {{if (eq this.payoutPeriod 'month') 'btn-primary' 'btn-default'}}" {{on "click" (fn this.setPayoutPeriod "month")}}>This Month</button>
        <button class="btn btn-small {{if (eq this.payoutPeriod '7days') 'btn-primary' 'btn-default'}}" {{on "click" (fn this.setPayoutPeriod "7days")}}>Last 7 Days</button>
      </div>

      {{#if this.adminPayoutSummary}}
        <div class="payout-summary-cards" style="margin-bottom:24px;">
          <div class="payout-summary-card">
            <div class="payout-summary-label">Total Gross</div>
            <div class="payout-summary-value">£{{this.adminPayoutSummary.total_gross}}</div>
          </div>
          <div class="payout-summary-card" style="border-color:var(--success);">
            <div class="payout-summary-label">RC Misfits Earned</div>
            <div class="payout-summary-value" style="color:var(--success);">£{{this.adminPayoutSummary.total_surcharge}}</div>
          </div>
          <div class="payout-summary-card">
            <div class="payout-summary-label">Total Paid Out</div>
            <div class="payout-summary-value">£{{this.adminPayoutSummary.total_paid}}</div>
          </div>
          <div class="payout-summary-card" style="border-color:var(--highlight);">
            <div class="payout-summary-label">Unclaimed</div>
            <div class="payout-summary-value" style="color:var(--highlight-high);">£{{this.adminPayoutSummary.total_unclaimed}}</div>
          </div>
        </div>
      {{/if}}

      {{#if this.adminPayoutsLoading}}
        <p>Loading payouts...</p>
      {{else if this.adminPayouts.length}}
        <table class="payout-history-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Organisation</th>
              <th>Date</th>
              <th>Gross</th>
              <th>Surcharge</th>
              <th>Net</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.adminPayouts as |payout|}}
              <tr>
                <td>{{payout.event_title}}</td>
                <td>{{payout.organisation_name}}</td>
                <td>{{payout.event_date}}</td>
                <td>£{{payout.gross_amount}}</td>
                <td>£{{payout.surcharge_amount}}</td>
                <td>£{{payout.net_amount}}</td>
                <td><span class="payout-status-badge payout-status--{{payout.status}}">{{payout.status}}</span></td>
                <td>
                  {{#if (eq payout.status "pending")}}
                    <button class="btn btn-primary btn-small" {{on "click" (fn this.adminApprovePayout payout)}} disabled={{this.approvingPayoutId}}>
                      {{if (eq this.approvingPayoutId payout.event_id) "..." "✅ Approve"}}
                    </button>
                  {{else}}
                    <span style="color:var(--primary-medium);font-size:0.85em;">{{payout.status}}</span>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p class="field-help">No payouts found for this period.</p>
      {{/if}}
    </div>
  {{/if}}

  {{!-- VENUE SUGGESTIONS TAB --}}
  {{#if (eq this.activeTab "suggestions")}}
    <div class="des-admin-section">
      <h2>💡 Pending Venue Suggestions</h2>
      {{#if this.suggestionsLoading}}
        <p class="field-help">Loading...</p>
      {{else if this.pendingSuggestions.length}}
        {{#each this.pendingSuggestions as |suggestion|}}
          <div class="admin-org-card" style="margin-bottom:12px;">
            <div class="admin-org-header">
              <strong>{{suggestion.venue_name}}</strong>
              <span class="field-help">by {{suggestion.user}} — {{suggestion.created_at}}</span>
            </div>
            <div style="padding:8px 12px;">
              <h4>Suggested changes:</h4>
              <pre style="background:var(--primary-very-low);padding:8px;border-radius:4px;font-size:0.85em;white-space:pre-wrap;max-height:200px;overflow:auto;">{{this.formatSuggestion suggestion.suggested_data}}</pre>
              <div style="display:flex;gap:8px;margin-top:8px;">
                <button class="btn btn-success btn-small" {{on "click" (fn this.approveSuggestion suggestion)}}>✅ Approve & Apply</button>
                <button class="btn btn-danger btn-small" {{on "click" (fn this.rejectSuggestion suggestion)}}>❌ Reject</button>
                <a href="/venues/{{suggestion.venue_id}}" class="btn btn-default btn-small" target="_blank">View Venue</a>
              </div>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="field-help">No pending suggestions.</p>
      {{/if}}

      {{#if this.resolvedSuggestions.length}}
        <h3 style="margin-top:24px;">Recent Resolved</h3>
        {{#each this.resolvedSuggestions as |suggestion|}}
          <div class="admin-org-card" style="margin-bottom:8px;opacity:0.7;">
            <div class="admin-org-header">
              <strong>{{suggestion.venue_name}}</strong>
              <span class="field-help">{{suggestion.status}} — by {{suggestion.user}} — {{suggestion.created_at}}</span>
              {{#if suggestion.admin_notes}}<span class="field-help">Note: {{suggestion.admin_notes}}</span>{{/if}}
            </div>
          </div>
        {{/each}}
      {{/if}}
    </div>
  {{/if}}

</div>

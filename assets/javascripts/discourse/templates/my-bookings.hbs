<div class="my-bookings-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="my-bookings" class="btn btn-default">🎟 My Bookings</LinkTo>
    <LinkTo @route="racing-profile" class="btn btn-default">👤 Profile</LinkTo>
    <LinkTo @route="my-garage" class="btn btn-default">🚗 My Garage</LinkTo>
  </div>

  <div class="my-bookings-header">
    <h1>My Bookings</h1>
  </div>

  {{#if this.model.length}}
    <div class="my-bookings-list">
      {{#each this.model as |booking|}}
        <div class="booking-card booking-card--{{booking.status}}">
          <div class="booking-card-header">
            <h2>{{booking.event.title}}</h2>
            <span class="booking-status booking-status--{{booking.status}}">
              {{booking.status}}
            </span>
          </div>

          <div class="booking-meta">
            <div>📅 {{booking.event.formatted_date}}</div>
            {{#if booking.event.location}}
              <div>📍 {{booking.event.location}}</div>
            {{/if}}
          </div>

          <div class="booking-classes">
            {{#each booking.classes as |cls|}}
              <div class="booking-class-item">
                <span class="booking-class-badge">{{cls.class_name}}</span>
                {{#if cls.transponder_number}}
                  <span class="transponder-number">📡 {{cls.transponder_number}}</span>
                {{/if}}
                <span class="booking-class-amount">£{{cls.amount_charged}}</span>
              </div>
            {{/each}}
          </div>

          <div class="booking-footer">
            <strong>Total paid: £{{booking.amount_paid}}</strong>
            <div class="booking-actions">
              {{#if booking.event.topic_url}}
                <a href={{booking.event.topic_url}} class="btn btn-small btn-default">
                  💬 Discussion
                </a>
              {{/if}}
              {{#unless (eq booking.status "cancelled")}}
                {{#unless (eq booking.status "refunded")}}
                  <button
                    class="btn btn-small btn-danger"
                    {{on "click" (fn this.cancelBooking booking.id)}}
                  >
                    Cancel Booking
                  </button>
                {{/unless}}
              {{/unless}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="my-bookings-empty">
      <p>You haven't made any bookings yet.</p>
      <LinkTo @route="events" class="btn btn-primary">
        Browse Events
      </LinkTo>
    </div>
  {{/if}}
</div>
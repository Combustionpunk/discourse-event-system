<div class="organisation-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="organisations" class="btn btn-default">🏢 Organisations</LinkTo>
  </div>

  <div class="org-detail-header">
    <div>
      {{#if this.model.logo_url}}
        <img src={{this.model.logo_url}} class="org-logo org-logo--large" alt="" />
      {{/if}}
      <h1>{{this.model.name}}</h1>
      <span class="org-status org-status--{{this.model.status}}">{{this.model.status}}</span>
    </div>
  </div>

  {{#if this.model.description}}
    <p class="org-detail-description">{{this.model.description}}</p>
  {{/if}}

  {{!-- Tabs for org admins --}}
  <div class="manage-tabs">
      <button class="manage-tab {{if (eq this.activeTab 'details') 'active'}}" {{on "click" this.showDetails}}>
        📋 Details
      </button>
      {{#if this.model.is_admin}}
      <button class="manage-tab {{if (eq this.activeTab 'memberships') 'active'}}" {{on "click" this.showMemberships}}>
        🎫 Memberships
      </button>
      {{/if}}
      {{#if this.model.is_admin}}
        <button class="manage-tab {{if (eq this.activeTab 'members') 'active'}}" {{on "click" this.showMembers}}>
          👥 Members
        </button>
        <button class="manage-tab {{if (eq this.activeTab 'events') 'active'}}" {{on "click" this.showEvents}}>
          📅 Events
        </button>
        <button class="manage-tab {{if (eq this.activeTab 'rules') 'active'}}" {{on "click" this.showRules}}>
          ⚙️ Class Rules
        </button>
        <button class="manage-tab {{if (eq this.activeTab 'settings') 'active'}}" {{on "click" this.showSettings}}>
          ⚙️ Settings
        </button>
      {{/if}}
    </div>

  {{!-- Details Tab --}}
  {{#if (eq this.activeTab 'details')}}
    <div class="org-detail-grid">
      <div class="org-detail-info">
        <h2>Details</h2>
        <div class="org-info-list">
          {{#if this.model.email}}
            <div class="org-info-item">
              <span class="org-info-label">✉️ Email</span>
              <a href="mailto:{{this.model.email}}">{{this.model.email}}</a>
            </div>
          {{/if}}
          {{#if this.model.phone}}
            <div class="org-info-item">
              <span class="org-info-label">📞 Phone</span>
              <span>{{this.model.phone}}</span>
            </div>
          {{/if}}
          {{#if this.model.website}}
            <div class="org-info-item">
              <span class="org-info-label">🌐 Website</span>
              <a href={{this.model.website}} target="_blank">{{this.model.website}}</a>
            </div>
          {{/if}}
          {{#if this.model.address}}
            <div class="org-info-item">
              <span class="org-info-label">📍 Address</span>
              <span>{{this.model.address}}</span>
            </div>
          {{/if}}
          {{#if this.model.google_maps_url}}
            <div class="org-info-item">
              <a href={{this.model.google_maps_url}} target="_blank" class="btn btn-small btn-default">
                📍 View on Google Maps
              </a>
            </div>
          {{/if}}
        </div>
      </div>
    </div>

    {{!-- Public membership section --}}
    {{#if this.model.membership_types.length}}
      <div class="org-memberships-public">
        <h2>🎫 Memberships</h2>
        <p class="field-help">Join {{this.model.name}} to become an official member.</p>
        <div class="membership-types-list">
          {{#each this.model.membership_types as |mtype|}}
            <div class="membership-type-card">
              <div class="membership-type-info">
                <h3>{{mtype.name}}</h3>
                {{#if mtype.description}}<p class="field-help">{{mtype.description}}</p>{{/if}}
                <div class="membership-type-meta">
                  <span class="booking-class-badge">£{{mtype.price}}</span>
                  <span class="field-help">{{mtype.duration_months}} months</span>
                  {{#if mtype.discount_percentage}}
                    <span class="rule-type-badge rule-type-badge--driveline">{{mtype.discount_percentage}}% event discount</span>
                  {{/if}}
                  {{#if mtype.is_family}}
                    <span class="rule-type-badge rule-type-badge--chassis">👨‍👩‍👧 Family (up to {{mtype.max_members}})</span>
                  {{/if}}
                </div>
              </div>
              {{#if this.currentUser}}
                {{#if this.model.is_member}}
                  <span class="org-status org-status--active">✅ Member</span>
                {{else}}
                  <button
                    class="btn btn-primary"
                    {{on "click" (fn this.joinMembership mtype.id mtype.is_family mtype.max_members)}}
                  >
                    {{if (eq this.joiningMembershipTypeId mtype.id) "Cancel" "Join"}}
                  </button>
                {{/if}}
              {{else}}
                <a href="/login" class="btn btn-default">Log in to Join</a>
              {{/if}}
              {{!-- Inline family member form --}}
              {{#if (eq this.joiningMembershipTypeId mtype.id)}}
                {{#if mtype.is_family}}
                  <div class="family-inline-form">
                    <p class="field-help">Add up to {{this.maxFamilyMembers}} members total (including yourself).</p>
                    <div style="margin-bottom:8px;">
                      <div style="display:flex; gap:8px;">
                        <input
                          type="text"
                          placeholder="Type username to search..."
                          value={{this.familyMemberSearch}}
                          {{on "input" this.updateFamilySearch}}
                          autocomplete="off"
                        />
                        <button class="btn btn-small btn-default" {{on "click" this.addFamilyMemberToList}}>
                          + Add
                        </button>
                      </div>
                      {{#if this.familyUserSearchResults.length}}
                        <div class="family-search-results">
                          {{#each this.familyUserSearchResults as |user|}}
                            <div class="family-search-result" {{on "click" (fn this.selectFamilyUser user.username)}}>
                              <img src={{user.avatar_template}} class="user-avatar" alt={{user.username}} />
                              <span class="user-username">{{user.username}}</span>
                              {{#if user.name}}<span class="user-name">{{user.name}}</span>{{/if}}
                            </div>
                          {{/each}}
                        </div>
                      {{/if}}
                    </div>
                    {{#each this.familyMemberUsernames as |username|}}
                      <div class="rule-row" style="margin-bottom:4px;">
                        <span style="flex:1">👤 {{username}}</span>
                        <button class="btn btn-small btn-danger" {{on "click" (fn this.removeFamilyMemberFromList username)}}>✕</button>
                      </div>
                    {{/each}}
                    <div style="margin-top:12px; display:flex; gap:8px;">
                      <button class="btn btn-primary" {{on "click" this.confirmFamilyJoin}}>
                        Proceed to Payment
                      </button>
                      <button class="btn btn-default" {{on "click" this.cancelFamilyModal}}>
                        Cancel
                      </button>
                    </div>
                  </div>
                {{/if}}
              {{/if}}
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{#if this.model.events.length}}
      <div class="org-detail-events">
        <h2>Upcoming Events</h2>
        <div class="org-events-list">
          {{#each this.model.events as |event|}}
            <div class="org-event-item">
              <LinkTo @route="event" @model={{event.id}}>{{event.title}}</LinkTo>
              <div style="display:flex; gap:8px; align-items:center;">
                <span class="event-status event-status--{{event.status}}">{{event.status}}</span>
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}
  {{/if}}

  {{!-- Members Tab --}}
  {{#if (eq this.activeTab 'members')}}
    <div class="org-detail-members">
      <div class="org-section-header">
        <h2>Members</h2>
        {{#if this.model.is_admin}}
          <button class="btn btn-small btn-primary" {{on "click" this.toggleAddMember}}>
            {{if this.showAddMember "Cancel" "+ Add Member"}}
          </button>
        {{/if}}
      </div>

      {{#if this.showAddMember}}
        <div class="add-member-form">
          <div class="org-form-row">
            <div class="org-form-field user-search-field">
              <label>Search User</label>
              <input
                type="text"
                placeholder="Type to search users..."
                value={{this.newMemberUsername}}
                {{on "input" this.updateUsername}}
              />
              {{#if this.userSearchResults.length}}
                <div class="user-search-results">
                  {{#each this.userSearchResults as |user|}}
                    <div class="user-search-result" {{on "click" (fn this.selectUser user.username)}}>
                      <img src={{user.avatar_template}} class="user-avatar" alt={{user.username}} />
                      <span class="user-username">{{user.username}}</span>
                      {{#if user.name}}
                        <span class="user-name">{{user.name}}</span>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
            <div class="org-form-field">
              <label>Position</label>
              <select {{on "change" this.updatePosition}}>
                <option value="">Select position...</option>
                {{#each this.model.positions as |pos|}}
                  <option value={{pos.id}}>{{pos.name}}</option>
                {{/each}}
              </select>
            </div>
          </div>
          <button class="btn btn-primary" disabled={{this.isSaving}} {{on "click" this.addMember}}>
            {{if this.isSaving "Adding..." "Add Member"}}
          </button>
        </div>
      {{/if}}

      {{#if this.model.members.length}}
        <div class="members-list">
          {{#each this.model.members as |member|}}
            <div class="member-item">
              <div class="member-info">
                <strong>{{member.user.username}}</strong>
                <span class="member-position">{{member.position.name}}</span>
              </div>
              {{#if this.model.is_admin}}
                <button class="btn btn-small btn-danger" {{on "click" (fn this.removeMember member.id)}}>
                  Remove
                </button>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="field-help">No members yet.</p>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Admin Memberships Section --}}
  {{#if (eq this.activeTab 'members')}}
    {{#if this.model.is_admin}}
      <div class="manage-section" style="margin-top: 24px;">
        <div class="org-section-header">
          <h2>🎫 Memberships</h2>
          <button class="btn btn-small btn-primary" {{on "click" this.toggleAddMembership}}>
            {{if this.showAddMembership "Cancel" "+ Add Membership"}}
          </button>
        </div>

        {{#if this.showAddMembership}}
          <div class="add-member-form">
            <div class="org-form-row">
              <div class="org-form-field">
                <label>Username *</label>
                <input type="text" placeholder="username" value={{this.newMembershipUsername}} {{on "input" (fn this.updateNewMembershipField "username")}} />
              </div>
              <div class="org-form-field">
                <label>Membership Type *</label>
                <select {{on "change" (fn this.updateNewMembershipField "membership_type_id")}}>
                  <option value="">Select type...</option>
                  {{#each this.model.membership_types as |mtype|}}
                    <option value={{mtype.id}}>{{mtype.name}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="org-form-row">
              <div class="org-form-field">
                <label>Expires At</label>
                <input type="date" value={{this.newMembershipExpiresAt}} {{on "change" (fn this.updateNewMembershipField "expires_at")}} />
              </div>
              <div class="org-form-field">
                <label>Amount Paid (£)</label>
                <input type="number" min="0" step="0.01" placeholder="0" value={{this.newMembershipAmountPaid}} {{on "input" (fn this.updateNewMembershipField "amount_paid")}} />
              </div>
            </div>
            {{#if this.selectedTypeIsFamily}}
              <div class="org-form-field">
                <label>Family Members (up to {{this.selectedTypeMaxFamilyMembers}})</label>
                {{#each this.newMembershipFamilyUsernames as |username index|}}
                  <div class="family-username-row" style="display:flex; gap:8px; margin-bottom:4px;">
                    <input
                      type="text"
                      placeholder="Username"
                      value={{username}}
                      {{on "input" (fn this.updateFamilyUsername index)}}
                    />
                    <button class="btn btn-small btn-danger" {{on "click" (fn this.removeFamilyUsernameField index)}}>
                      Remove
                    </button>
                  </div>
                {{/each}}
                <button class="btn btn-small btn-default" {{on "click" this.addFamilyUsernameField}}>
                  + Add Family Member
                </button>
              </div>
            {{/if}}

            <button class="btn btn-primary" {{on "click" this.saveAdminMembership}}>
              Add Membership
            </button>
          </div>
        {{/if}}

        {{#each this.adminMemberships as |m|}}
          <div class="admin-org-card">
            <div class="admin-org-info">
              <strong>{{m.username}}</strong>
              <div class="admin-org-meta">
                <span>{{m.membership_type}}</span>
                <span class="booking-status booking-status--{{m.status}}">{{m.status}}</span>
                {{#if m.expires_at}}<span>Expires: {{m.expires_at}}</span>{{/if}}
                {{#if m.is_family}}
                  <span>👨‍👩‍👧 {{m.family_members.length}}/{{m.max_members}} members</span>
                {{/if}}
              </div>
            </div>
            <div class="admin-org-actions">
              <select class="membership-status-select" {{on "change" (fn this.changeMembershipStatus m)}}>
                <option value="active" selected={{eq m.status "active"}}>Active</option>
                <option value="pending" selected={{eq m.status "pending"}}>Pending</option>
                <option value="expired" selected={{eq m.status "expired"}}>Expired</option>
                <option value="cancelled" selected={{eq m.status "cancelled"}}>Cancelled</option>
              </select>
              {{#if (eq this.editingMembershipId m.id)}}
                <input type="date" value={{this.editingMembershipExpiry}} {{on "change" this.updateEditingExpiry}} />
                <button class="btn btn-primary btn-small" {{on "click" this.saveEditMembership}}>Save</button>
                <button class="btn btn-default btn-small" {{on "click" this.cancelEditMembership}}>Cancel</button>
              {{else}}
                <button class="btn btn-small btn-default" {{on "click" (fn this.editMembership m)}}>📅 Expiry</button>
                {{#if m.is_family}}
                  <button class="btn btn-small btn-default" {{on "click" (fn this.toggleManageFamily m.id)}}>
                    👨‍👩‍👧 Family
                  </button>
                {{/if}}
                <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteMembership m)}}>
                  🗑 Delete
                </button>
              {{/if}}
            </div>
          </div>

          {{#if m.is_family}}
            {{#if (eq this.managingFamilyMembershipId m.id)}}
              <div class="family-manage-panel" style="margin-left:16px; padding:8px; border-left:3px solid var(--primary-low,#ddd); margin-bottom:8px;">
                <h4>Family Members</h4>
                {{#if m.family_members.length}}
                  {{#each m.family_members as |fm|}}
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
                      <strong>{{fm.username}}</strong>
                      {{#if (eq this.editingFamilyDobKey (concat m.id "_" fm.user_id))}}
                        <input
                          type="date"
                          value={{this.editingFamilyDobValue}}
                          {{on "change" this.updateEditingFamilyDob}}
                        />
                        <button class="btn btn-small btn-primary" {{on "click" (fn this.saveEditFamilyDob m.id fm.user_id)}}>Save</button>
                        <button class="btn btn-small btn-default" {{on "click" this.cancelEditFamilyDob}}>Cancel</button>
                      {{else}}
                        <span class="field-help">
                          DOB: {{if fm.date_of_birth fm.date_of_birth "Not set"}}
                        </span>
                        <button class="btn btn-small btn-default" {{on "click" (fn this.startEditFamilyDob m.id fm.user_id fm.date_of_birth)}}>
                          {{if fm.date_of_birth "Edit DOB" "Set DOB"}}
                        </button>
                      {{/if}}
                      <button class="btn btn-small btn-danger" {{on "click" (fn this.removeAdminFamilyMember m.id fm.user_id)}}>
                        Remove
                      </button>
                    </div>
                  {{/each}}
                {{else}}
                  <p class="field-help">No family members added yet.</p>
                {{/if}}

                <div style="display:flex; gap:8px; margin-top:8px; align-items:flex-end;">
                  <div>
                    <label class="field-help">Username</label>
                    <input
                      type="text"
                      placeholder="Username"
                      value={{this.newFamilyMemberUsername}}
                      {{on "input" this.updateNewFamilyMemberUsername}}
                    />
                  </div>
                  <div>
                    <label class="field-help">Date of Birth</label>
                    <input
                      type="date"
                      value={{this.newFamilyMemberDob}}
                      {{on "change" this.updateNewFamilyMemberDob}}
                    />
                  </div>
                  <button class="btn btn-small btn-primary" {{on "click" (fn this.addAdminFamilyMember m.id)}}>
                    Add
                  </button>
                </div>
              </div>
            {{/if}}
          {{/if}}
        {{/each}}
      </div>
    {{/if}}
  {{/if}}

  {{!-- Events Tab --}}
  {{#if (eq this.activeTab 'events')}}
    <div class="org-detail-events">
      <div class="org-section-header">
        <h2>Events</h2>
        <LinkTo @route="event-new" class="btn btn-small btn-primary">+ New Event</LinkTo>
      </div>
      {{#if this.model.events.length}}
        <div class="org-events-list">
          {{#each this.model.events as |event|}}
            <div class="org-event-item">
              <LinkTo @route="event" @model={{event.id}}>{{event.title}}</LinkTo>
              <div style="display:flex; gap:8px; align-items:center;">
                <span class="event-status event-status--{{event.status}}">{{event.status}}</span>
                <LinkTo @route="event-manage" @model={{event.id}} class="btn btn-small btn-default">
                  ⚙️ Manage
                </LinkTo>
              </div>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="field-help">No events yet.</p>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Class Rules Tab --}}
  {{#if (eq this.activeTab 'rules')}}
    <div class="manage-section">
      <h2>Organisation Class Types</h2>
      <p class="field-help">Create custom class types for your organisation's events with their own eligibility rules.</p>

      <div class="admin-rule-form">
        <h3>Create New Class Type</h3>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Class Name</label>
            <input type="text" id="new-class-type-name" placeholder="e.g. Our Fun Class" />
          </div>
          <div class="org-form-field">
            <label>Description <span class="field-help">(optional)</span></label>
            <input type="text" id="new-class-type-desc" placeholder="Brief description" />
          </div>
          <div class="org-form-field" style="justify-content: flex-end;">
            <button class="btn btn-primary" {{on "click" this.createClassType}}>
              + Create Class
            </button>
          </div>
        </div>
      </div>

      {{#if this.model.org_class_types.length}}
        {{#each this.model.org_class_types as |ct|}}
          <div class="rules-class-group">
            <div class="org-section-header">
              <h4>{{ct.name}} {{#if ct.description}}<span class="field-help">— {{ct.description}}</span>{{/if}}</h4>
              <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteClassType ct.id)}}>
                🗑 Delete Class
              </button>
            </div>

            {{#each ct.rules as |rule|}}
              <div class="rule-row">
                <span class="rule-type-badge rule-type-badge--{{rule.rule_type}}">{{this.ruleTypeLabel rule.rule_type}}</span>
                <span class="rule-value">{{rule.rule_value}}</span>
                <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteClassTypeRule ct.id rule.id)}}>
                  🗑
                </button>
              </div>
            {{/each}}

            <div class="add-rule-inline">
              <select class="rule-type-select" data-class-id={{ct.id}} {{on "change" (fn this.onRuleTypeChange ct.id)}}>
                <option value="driveline">Driveline</option>
                <option value="chassis">Chassis Type</option>
                <option value="manufacturer">Manufacturer</option>
                <option value="max_year">Max Year (on or before)</option>
                <option value="min_year">Min Year (on or after)</option>
                <option value="max_age">Max Driver Age</option>
                <option value="min_age">Min Driver Age</option>
              </select>

              <div class="rule-value-container rule-value-container--driveline" data-class-id={{ct.id}}>
                <select class="rule-multiselect" data-class-id={{ct.id}} multiple size="4">
                  {{#each this.model.drivelines as |dl|}}
                    <option value={{dl}}>{{dl}}</option>
                  {{/each}}
                </select>
                <span class="field-help">Hold Ctrl/Cmd to select multiple</span>
              </div>

              <div class="rule-value-container rule-value-container--chassis" data-class-id={{ct.id}} style="display:none">
                <select class="rule-multiselect" data-class-id={{ct.id}} multiple size="4">
                  {{#each this.model.chassis_types as |ct2|}}
                    <option value={{ct2}}>{{ct2}}</option>
                  {{/each}}
                </select>
                <span class="field-help">Hold Ctrl/Cmd to select multiple</span>
              </div>

              <div class="rule-value-container rule-value-container--manufacturer" data-class-id={{ct.id}} style="display:none">
                <select class="rule-multiselect" data-class-id={{ct.id}} multiple size="4">
                  {{#each this.model.manufacturers as |m|}}
                    <option value={{m.name}}>{{m.name}}{{#if (eq m.status 'pending')}} (pending){{/if}}</option>
                  {{/each}}
                </select>
                <span class="field-help">Hold Ctrl/Cmd to select multiple</span>
              </div>

              <div class="rule-value-container rule-value-container--year" data-class-id={{ct.id}} style="display:none">
                <select class="rule-year-select" data-class-id={{ct.id}}>
                  {{#each this.yearOptions as |year|}}
                    <option value={{year}}>{{year}}</option>
                  {{/each}}
                </select>
              </div>

              <div class="rule-value-container rule-value-container--age" data-class-id={{ct.id}} style="display:none">
                <input type="number" class="rule-age-input" data-class-id={{ct.id}} min="1" max="100" placeholder="Age" style="width: 80px;" />
              </div>

              <button class="btn btn-small btn-default" {{on "click" (fn this.addClassTypeRule ct.id)}}>
                + Add Rule
              </button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="field-help">No custom class types yet. Create one above!</p>
      {{/if}}

      <div style="margin-top: 32px;">
        <h3>Global Class Types</h3>
        <p class="field-help">These are available to all organisations. You can also use these when setting up events.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
          {{#each this.model.global_class_types as |ct|}}
            <span class="booking-class-badge">{{ct.name}}</span>
          {{/each}}
        </div>
      </div>
    </div>
  {{/if}}

  {{!-- Memberships Tab --}}
  {{#if (eq this.activeTab 'memberships')}}
    <div class="manage-section">
      <h2>Membership Types</h2>
      <p class="field-help">Set up membership types that users can purchase to join your organisation.</p>

      <div class="admin-rule-form">
        <h3>Add Membership Type</h3>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Name</label>
            <input type="text" id="mtype-name" placeholder="e.g. Annual Member" />
          </div>
          <div class="org-form-field">
            <label>Price (£)</label>
            <input type="number" id="mtype-price" placeholder="30.00" step="0.01" min="0" />
          </div>
          <div class="org-form-field">
            <label>Duration (months)</label>
            <input type="number" id="mtype-duration" placeholder="12" min="1" />
          </div>
        </div>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Description <span class="field-help">(optional)</span></label>
            <input type="text" id="mtype-desc" placeholder="Brief description" />
          </div>
          <div class="org-form-field">
            <label>Event Discount % <span class="field-help">(optional)</span></label>
            <input type="number" id="mtype-discount" placeholder="0" min="0" max="100" />
          </div>
          <div class="org-form-field">
            <label>Max Members <span class="field-help">(1 = individual, 2+ = family)</span></label>
            <input type="number" id="mtype-max-members" placeholder="1" min="1" max="10" value="1" />
          </div>
          <div class="org-form-field" style="justify-content: flex-end;">
            <button class="btn btn-primary" {{on "click" this.createMembershipType}}>
              + Add Type
            </button>
          </div>
        </div>
      </div>

      {{#if this.model.membership_types.length}}
        {{#each this.model.membership_types as |mtype|}}
          <div class="rules-class-group">
            <div class="org-section-header">
              <div>
                <h4>{{mtype.name}}
                  <span class="booking-class-badge">£{{mtype.price}}</span>
                  <span class="field-help">{{mtype.duration_months}} months</span>
                  {{#if mtype.discount_percentage}}
                    <span class="rule-type-badge rule-type-badge--driveline">{{mtype.discount_percentage}}% discount</span>
                  {{/if}}
                  {{#if mtype.is_family}}
                    <span class="rule-type-badge rule-type-badge--chassis">👨‍👩‍👧 Family (up to {{mtype.max_members}})</span>
                  {{/if}}
                </h4>
                {{#if mtype.description}}<p class="field-help">{{mtype.description}}</p>{{/if}}
              </div>
              <button class="btn btn-small btn-danger" {{on "click" (fn this.deleteMembershipType mtype.id)}}>
                🗑 Remove
              </button>
            </div>
          </div>
        {{/each}}
      {{else}}
        <p class="field-help">No membership types yet. Add one above!</p>
      {{/if}}
    </div>
  {{/if}}


  {{!-- Settings Tab --}}
  {{#if (eq this.activeTab "settings")}}
    <div class="manage-section">
      <h2>Organisation Settings</h2>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>Organisation Name *</label>
          <input type="text" value={{this.settingsForm.name}} {{on "input" (fn this.updateSettingsField "name")}} />
        </div>
        <div class="org-form-field">
          <label>Email</label>
          <input type="email" value={{this.settingsForm.email}} {{on "input" (fn this.updateSettingsField "email")}} />
        </div>
      </div>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>Phone</label>
          <input type="text" value={{this.settingsForm.phone}} {{on "input" (fn this.updateSettingsField "phone")}} />
        </div>
        <div class="org-form-field">
          <label>Website</label>
          <input type="url" value={{this.settingsForm.website}} {{on "input" (fn this.updateSettingsField "website")}} />
        </div>
      </div>
      <div class="org-form-field">
        <label>Logo URL</label>
        <input type="url" value={{this.settingsForm.logo_url}} placeholder="https://example.com/logo.png" {{on "input" (fn this.updateSettingsField "logo_url")}} />
        {{#if this.settingsForm.logo_url}}
          <img src={{this.settingsForm.logo_url}} class="org-logo org-logo--small" alt="Preview" style="margin-top:8px;" />
        {{/if}}
      </div>
      <div class="org-form-field">
        <label>Address</label>
        <input type="text" value={{this.settingsForm.address}} {{on "input" (fn this.updateSettingsField "address")}} />
      </div>
      <div class="org-form-field">
        <label>Google Maps URL</label>
        <input type="url" value={{this.settingsForm.google_maps_url}} {{on "input" (fn this.updateSettingsField "google_maps_url")}} />
      </div>
      <div class="org-form-field">
        <label>Description</label>
        <textarea rows="4" {{on "input" (fn this.updateSettingsField "description")}}>{{this.settingsForm.description}}</textarea>
      </div>
      <button class="btn btn-primary" {{on "click" this.saveSettings}}>
        💾 Save Settings
      </button>
    </div>
  {{/if}}
</div>
<div class="event-new-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="organisations" class="btn btn-default">🏢 Organisations</LinkTo>
  </div>

  <h1>Create New Event</h1>

  <div class="event-new-form">

    <div class="event-form-section">
      <h2>Basic Details</h2>

      <div class="org-form-field">
        <label>Organisation *</label>
        <select {{on "change" (fn this.updateField "organisation_id")}}>
          <option value="">Select organisation...</option>
          {{#each this.model.organisations as |org|}}
            <option value={{org.id}}>{{org.name}}</option>
          {{/each}}
        </select>
      </div>

      <div class="org-form-row">
        <div class="org-form-field">
          <label>Event Title *</label>
          <input
            type="text"
            placeholder="e.g. Summer RC Championship 2026"
            {{on "input" (fn this.updateField "title")}}
          />
        </div>
        <div class="org-form-field">
          <label>Event Type *</label>
          <select {{on "change" (fn this.updateField "event_type_id")}}>
            <option value="">Select type...</option>
            {{#each this.model.event_types as |et|}}
              <option value={{et.id}}>{{et.name}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div style="width:100%;margin-bottom:16px;">
        <label style="display:block;font-weight:bold;margin-bottom:6px;">Description</label>
        <div class="des-editor-wrapper">
          <DEditor
            @value={{this.description}}
            @placeholder="Tell racers about this event..."
            @processPreview={{false}}
          />
        </div>
      </div>

      <div class="org-form-field">
        <label>Location</label>
        <input
          type="text"
          placeholder="e.g. Midlands RC Circuit, Birmingham"
          {{on "input" (fn this.updateField "location")}}
        />
      </div>

      <div class="org-form-field">
        <label>Google Maps URL</label>
        <input
          type="url"
          placeholder="https://maps.google.com/..."
          {{on "input" (fn this.updateField "google_maps_url")}}
        />
      </div>

      <div class="org-form-row">
        <div class="org-form-field">
          <label>Start Date & Time *</label>
          <input
            type="datetime-local"
            {{on "change" (fn this.updateField "start_date")}}
          />
        </div>
        <div class="org-form-field">
          <label>End Date & Time</label>
          <input
            type="datetime-local"
            {{on "change" (fn this.updateField "end_date")}}
          />
        </div>
      </div>

      <div class="org-form-field">
        <label>Booking Method *</label>
        <select {{on "change" (fn this.updateField "booking_type")}}>
          <option value="internal">Online via this system (PayPal)</option>
          <option value="external">Booked externally</option>
        </select>
      </div>

      {{#if this.isExternalBooking}}
        <div class="org-form-field">
          <label>External Booking URL</label>
          <input
            type="url"
            placeholder="https://brca.org/book..."
            {{on "input" (fn this.updateField "external_booking_url")}}
          />
        </div>
        <div class="org-form-field">
          <label>Booking Details</label>
          <textarea
            placeholder="e.g. Book via BRCA website. Enter class and transponder number on the entry form."
            {{on "input" (fn this.updateField "external_booking_details")}}
          ></textarea>
        </div>
      {{else}}
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Booking Closing Date</label>
            <input
              type="datetime-local"
              {{on "change" (fn this.updateField "booking_closing_date")}}
            />
          </div>
          <div class="org-form-field">
            <label>Refund Cutoff (days before event)</label>
            <input
              type="number"
              value="7"
              min="0"
              {{on "input" (fn this.updateField "refund_cutoff_days")}}
            />
          </div>
          <div class="org-form-field">
            <label>Max Classes Per Booking</label>
            <input
              type="number"
              min="1"
              placeholder="Leave blank for unlimited"
              {{on "input" (fn this.updateField "max_classes_per_booking")}}
            />
            <p class="field-help">Limit how many classes a user can book in one booking. Leave blank for unlimited.</p>
          </div>
        </div>
      {{/if}}

      {{!-- Discounts --}}
      <div class="org-form-section">
        <h3>Discounts <span class="field-help">(optional - flat rate deductions)</span></h3>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Member - 1st Class Discount (£)</label>
            <input type="number" min="0" step="0.50" placeholder="0"
              {{on "input" (fn this.updatePricing "member_first_class_discount")}} />
          </div>
          <div class="org-form-field">
            <label>Member - Subsequent Classes (£)</label>
            <input type="number" min="0" step="0.50" placeholder="0"
              {{on "input" (fn this.updatePricing "member_subsequent_discount")}} />
          </div>
        </div>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Junior (U16) - 1st Class Discount (£)</label>
            <input type="number" min="0" step="0.50" placeholder="0"
              {{on "input" (fn this.updatePricing "junior_first_class_discount")}} />
          </div>
          <div class="org-form-field">
            <label>Junior (U16) - Subsequent Classes (£)</label>
            <input type="number" min="0" step="0.50" placeholder="0"
              {{on "input" (fn this.updatePricing "junior_subsequent_discount")}} />
          </div>
        </div>
      </div>
    </div>

    {{!-- Classes --}}
    <div class="event-form-section">
      <div class="org-section-header">
        <h2>Classes</h2>
        <button class="btn btn-small btn-primary" {{on "click" this.addClass}}>
          + Add Class
        </button>
      </div>

      {{#if this.classes.length}}
        <div class="classes-list">
          {{#each this.classes as |cls index|}}
            <div class="class-row">
              <div class="org-form-field">
                <label>Class Type</label>
                <select value={{cls.class_type_id}} {{on "change" (fn this.updateClass index "class_type_id")}}>
                  <option value="">Select class...</option>
                  <option value="">Select class type...</option>
                  <optgroup label="Global Classes">
                  {{#each this.globalClassTypes as |ct|}}
                    <option value={{ct.id}} selected={{eq (concat ct.id "") cls.class_type_id}}>{{ct.name}}</option>
                  {{/each}}
                  </optgroup>
                  {{#if this.orgClassTypes.length}}
                    <optgroup label="Organisation Classes">
                    {{#each this.orgClassTypes as |ct|}}
                      <option value={{ct.id}} selected={{eq (concat ct.id "") cls.class_type_id}}>{{ct.name}}</option>
                    {{/each}}
                    </optgroup>
                  {{/if}}
                </select>
              </div>
              <div class="org-form-field">
                <label>Capacity</label>
                <input
                  type="number"
                  value={{cls.capacity}}
                  min="1"
                  {{on "input" (fn this.updateClass index "capacity")}}
                />
              </div>
              <button
                class="btn btn-small btn-danger remove-class-btn"
                {{on "click" (fn this.removeClass index)}}
              >
                ✕
              </button>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="field-help">No classes added yet. Click "+ Add Class" to add one.</p>
      {{/if}}
    </div>

    {{!-- Pricing - only for internal bookings --}}
    {{#unless this.isExternalBooking}}
      <div class="event-form-section">
        <h2>Pricing</h2>

        <div class="org-form-field">
          <label>Pricing Type</label>
          <select {{on "change" this.updatePricingType}}>
            <option value="tiered">Tiered (different price for first class)</option>
            <option value="flat">Flat (same price per class)</option>
          </select>
        </div>

        {{#if this.pricingIsFlat}}
          <div class="org-form-field">
            <label>Price per class (£)</label>
            <input
              type="number"
              placeholder="e.g. 20"
              min="0"
              step="0.01"
              {{on "input" (fn this.updatePricing "flat_price")}}
            />
          </div>
        {{else}}
          <div class="org-form-row">
            <div class="org-form-field">
              <label>First Class Price (£)</label>
              <input
                type="number"
                placeholder="e.g. 20"
                min="0"
                step="0.01"
                {{on "input" (fn this.updatePricing "first_class_price")}}
              />
            </div>
            <div class="org-form-field">
              <label>Additional Classes Price (£)</label>
              <input
                type="number"
                placeholder="e.g. 10"
                min="0"
                step="0.01"
                {{on "input" (fn this.updatePricing "subsequent_class_price")}}
              />
            </div>
          </div>
        {{/if}}
      </div>
    {{/unless}}

    <div class="event-form-actions">
      <button
        class="btn btn-primary"
        disabled={{this.isSaving}}
        {{on "click" this.saveEvent}}
      >
        {{if this.isSaving "Saving..." "Save as Draft"}}
      </button>
      <LinkTo @route="events" class="btn btn-default">Cancel</LinkTo>
    </div>
  </div>
</div>
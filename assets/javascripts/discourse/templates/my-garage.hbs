<div class="garage-container">
  <div class="events-nav">
    <LinkTo @route="my-organisations" class="btn btn-default">🏢 My Organisations</LinkTo>
    <LinkTo @route="racing-profile" class="btn btn-default">🏎️ My Racing Profile</LinkTo>
    <LinkTo @route="my-garage" class="btn btn-default">🚗 My Garage</LinkTo>
    <LinkTo @route="my-bookings" class="btn btn-default">🎟️ My Bookings</LinkTo>
    <LinkTo @route="my-memberships" class="btn btn-default">🎫 My Memberships</LinkTo>
  </div>

  <div class="garage-header">
    <h1>🚗 My Garage</h1>
    <button class="btn btn-primary" {{on "click" this.toggleAddForm}}>
      {{if this.showAddForm "Cancel" "+ Add Car"}}
    </button>
  </div>

  {{#if this.showAddForm}}
    <div class="add-car-form">
      <h2>Add Car to Garage</h2>

      <div class="org-form-row">
        <div class="org-form-field">
          <label>Friendly Name</label>
          <input type="text" placeholder="e.g. Blue Bomber" {{on "input" (fn this.updateField "friendly_name")}} />
        </div>
        <div class="org-form-field">
          <label>Transponder Number *</label>
          <input type="text" placeholder="e.g. 1234567" {{on "input" (fn this.updateField "transponder_number")}} />
        </div>
      </div>

      <div class="org-form-row">
        <div class="org-form-field">
          <label>Manufacturer *</label>
          <select {{on "change" this.selectManufacturer}}>
            <option value="">Select manufacturer...</option>
            {{#each this.model.manufacturers as |m|}}
              <option value={{m.id}}>
                {{m.name}}{{if (eq m.status "pending") " (awaiting approval)"}}
              </option>
            {{/each}}
          </select>
          <button class="btn btn-small btn-default suggest-btn" {{on "click" this.suggestManufacturer}}>
            + Suggest unlisted manufacturer
          </button>
        </div>

        {{#if this.newCar.manufacturer_id}}
          <div class="org-form-field">
            <label>Model</label>
            {{#if this.suggestedManufacturer}}
              <div class="alert-info">
                🕐 <strong>{{this.suggestedManufacturer.name}}</strong> submitted for approval.
                Please suggest a model below.
              </div>
            {{else if this.availableModels.length}}
              <select {{on "change" this.selectModel}}>
                <option value="">Select model...</option>
                {{#each this.availableModels as |m|}}
                  <option value={{m.id}}>
                    {{m.name}}
                    {{#if m.year_released}}({{m.year_released}}){{/if}}
                    {{#if m.driveline}}- {{m.driveline}}{{/if}}
                    {{if (eq m.status "pending") " (awaiting approval)"}}
                  </option>
                {{/each}}
              </select>
            {{else}}
              <p class="field-help">No approved models yet for this manufacturer.</p>
            {{/if}}
            <button class="btn btn-small btn-default suggest-btn" {{on "click" this.toggleSuggestModel}}>
              + Suggest unlisted model
            </button>
          </div>
        {{/if}}
      </div>

      {{#if this.showSuggestModel}}
        <div class="suggest-model-form">
          <h3>Suggest Unlisted Model</h3>
          <p class="field-help">Your suggestion will be reviewed by an admin. You can still add your car now.</p>
          <div class="org-form-row">
            <div class="org-form-field">
              <label>Model Name *</label>
              <input type="text" placeholder="e.g. RC10B7" value={{this.suggestModelName}} {{on "input" (fn this.updateSuggestField "suggestModelName")}} />
            </div>
            <div class="org-form-field">
              <label>Year of First Manufacture</label>
              <input type="number" placeholder="e.g. 1987" min="1970" max="2030" value={{this.suggestModelYear}} {{on "input" (fn this.updateSuggestField "suggestModelYear")}} />
            </div>
          </div>
          <div class="org-form-field">
            <label>Driveline</label>
            <select {{on "change" (fn this.updateSuggestField "suggestModelDriveline")}}>
              <option value="">Select driveline...</option>
              {{#each this.drivelines as |d|}}
                <option value={{d}}>{{d}}</option>
              {{/each}}
            </select>
          </div>
          <button class="btn btn-primary" disabled={{this.isSaving}} {{on "click" this.submitModelAndAddCar}}>
            {{if this.isSaving "Saving..." "Submit & Add to Garage"}}
          </button>
        </div>
      {{/if}}

      {{#if this.selectedModel}}
        <div class="org-form-field">
          <label>Driveline</label>
          <div class="driveline-readonly">
            <span class="driveline-badge">{{this.selectedModel.driveline}}</span>
            <span class="field-help">Set by manufacturer specification</span>
          </div>
        </div>
      {{/if}}

      {{#unless this.showSuggestModel}}
        <div class="org-form-actions">
          <button class="btn btn-primary" disabled={{this.isSaving}} {{on "click" this.saveCar}}>
            {{if this.isSaving "Saving..." "Add to Garage"}}
          </button>
        </div>
      {{/unless}}
    </div>
  {{/if}}

  {{#if this.model.cars.length}}
    <div class="garage-grid">
      {{#each this.model.cars as |car|}}
        <div class="garage-car-card">
          <div class="garage-car-header">
            <span class="garage-car-icon">🚗</span>
            <div class="garage-car-title">
              <strong>{{car.friendly_name}}</strong>
              {{#if car.driveline}}
                <span class="driveline-badge">{{car.driveline}}</span>
              {{/if}}
            </div>
          </div>

          <div class="garage-car-body">
            {{#if car.manufacturer}}
              <div class="garage-car-row">
                <span class="garage-car-label">🏭 Manufacturer</span>
                <span>{{car.manufacturer.name}}</span>
              </div>
            {{/if}}
            {{#if car.model}}
              <div class="garage-car-row">
                <span class="garage-car-label">📋 Model</span>
                <span>{{car.model.name}}
                  {{#if car.model.year_released}}({{car.model.year_released}}){{/if}}
                  {{#unless car.model_approved}}
                    <span class="pending-tag">pending</span>
                  {{/unless}}
                </span>
              </div>
              {{#if car.model.chassis_type}}
                <div class="garage-car-row">
                  <span class="garage-car-label">🏎️ Class</span>
                  <span>{{car.model.chassis_type}}</span>
                </div>
              {{/if}}
            {{else if car.custom_model_name}}
              <div class="garage-car-row">
                <span class="garage-car-label">📋 Model</span>
                <span>{{car.custom_model_name}} <span class="pending-tag">pending</span></span>
              </div>
            {{/if}}
            {{#if car.transponder_number}}
              <div class="garage-car-row">
                <span class="garage-car-label">📡 Transponder</span>
                <span class="transponder-number">{{car.transponder_number}}</span>
              </div>
            {{/if}}
          </div>

          <div class="garage-car-actions">
            <button class="btn btn-small btn-danger" {{on "click" (fn this.removeCar car.id)}}>
              🗑 Remove
            </button>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="events-empty">
      <p>Your garage is empty! Add your first car to get started.</p>
    </div>
  {{/if}}
</div>
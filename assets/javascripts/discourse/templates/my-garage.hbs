<div class="garage-container">
  <div class="events-nav">
    <LinkTo @route="my-organisations" class="btn btn-default">🏢 My Organisations</LinkTo>
    <LinkTo @route="racing-profile" class="btn btn-default">🏎️ My Racing Profile</LinkTo>
    <LinkTo @route="my-garage" class="btn btn-default">🚗 My Garage</LinkTo>
    <LinkTo @route="my-bookings" class="btn btn-default">🎟️ My Bookings</LinkTo>
    <LinkTo @route="my-memberships" class="btn btn-default">🎫 My Memberships</LinkTo>
  </div>

  <div class="garage-header">
    <h1>🚗 My Garage</h1>
    <button class="btn btn-primary" {{on "click" this.toggleAddForm}}>
      {{if this.showAddForm "Cancel" "+ Add Car"}}
    </button>
  </div>

  {{#if this.showAddForm}}
    <DesAddCarModal
      @onSave={{this.onCarAdded}}
      @onClose={{this.toggleAddForm}}
    />
  {{/if}}

  {{#if this.model.cars.length}}
    <div class="garage-grid">
      {{#each this.model.cars as |car|}}
        <div class="garage-car-card {{if (eq this.editingCarId car.id) 'garage-car-card--editing'}}">
          {{#if (eq this.editingCarId car.id)}}
            <div class="garage-car-edit-form">
              <div class="org-form-field">
                <label>Manufacturer</label>
                <select {{on "change" this.editSelectManufacturer}}>
                  <option value="">Select...</option>
                  {{#each this.model.manufacturers as |mfr|}}
                    <option value={{mfr.id}} selected={{eq (concat mfr.id "") (concat this.editingCar.manufacturer_id "")}}>{{mfr.name}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="org-form-field">
                <label>Model</label>
                <select {{on "change" (fn this.updateEditCarField "car_model_id")}}>
                  <option value="">Select...</option>
                  {{#each this.editModels as |m|}}
                    <option value={{m.id}} selected={{eq (concat m.id "") (concat this.editingCar.car_model_id "")}}>{{m.name}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="org-form-field">
                <label>Nickname</label>
                <input type="text" value={{this.editingCar.friendly_name}} {{on "input" (fn this.updateEditCarField "friendly_name")}} />
              </div>
              <div class="org-form-field">
                <label>Transponder</label>
                <select {{on "change" this.setEditCarTransponderMode}}>
                  {{#each this.userTransponders as |t|}}
                    <option value={{t.id}} selected={{eq this.editingCar.transponder_number t.long_code}}>#{{t.shortcode}} — {{t.long_code}}{{#if t.notes}} ({{t.notes}}){{/if}}</option>
                  {{/each}}
                  <option value="new" selected={{eq this.editCarTransponderMode "new"}}>✏️ Enter new code...</option>
                </select>
                {{#if (eq this.editCarTransponderMode "new")}}
                  <input type="text" placeholder="e.g. 1234567" value={{this.editCarTransponderNew}} {{on "input" this.updateEditCarTransponderNew}} style="margin-top: 6px;" />
                {{/if}}
              </div>

              <div class="garage-car-actions">
                <button class="btn btn-primary btn-small" {{on "click" this.saveEditCar}}>💾 Save</button>
                <button class="btn btn-default btn-small" {{on "click" this.cancelEditCar}}>✕ Cancel</button>
              </div>
            </div>
          {{else}}
            <div class="garage-car-header">
              <span class="garage-car-icon">🚗</span>
              <div class="garage-car-title">
                <strong>{{car.friendly_name}}</strong>
                {{#if car.driveline}}
                  <span class="driveline-badge">{{car.driveline}}</span>
                {{/if}}
              </div>
            </div>

            <div class="garage-car-body">
              {{#if car.manufacturer}}
                <div class="garage-car-row">
                  <span class="garage-car-label">🏭 Manufacturer</span>
                  <span>{{car.manufacturer.name}}</span>
                </div>
              {{/if}}
              {{#if car.model}}
                <div class="garage-car-row">
                  <span class="garage-car-label">📋 Model</span>
                  <span>{{car.model.name}}
                    {{#if car.model.year_released}}({{car.model.year_released}}){{/if}}
                    {{#unless car.model_approved}}
                      <span class="pending-tag">pending</span>
                    {{/unless}}
                  </span>
                </div>
                {{#if car.model.scale}}
                  <div class="garage-car-row">
                    <span class="garage-car-label">📏 Scale</span>
                    <span>{{car.model.scale}}</span>
                  </div>
                {{/if}}
                {{#if car.model.chassis_type}}
                  <div class="garage-car-row">
                    <span class="garage-car-label">🏎️ Chassis</span>
                    <span>{{car.model.chassis_type}}</span>
                  </div>
                {{/if}}
              {{else if car.custom_model_name}}
                <div class="garage-car-row">
                  <span class="garage-car-label">📋 Model</span>
                  <span>{{car.custom_model_name}} <span class="pending-tag">pending</span></span>
                </div>
              {{/if}}
              {{#if car.transponder_number}}
                <div class="garage-car-row">
                  <span class="garage-car-label">📡 Transponder</span>
                  <span class="transponder-number">{{transponder-display car.transponder_number this.userTransponders}}</span>
                </div>
              {{/if}}
            </div>

            <div class="garage-car-actions">
              <button class="btn btn-small btn-default" {{on "click" (fn this.editCar car)}}>
                ✏️ Edit
              </button>
              <button class="btn btn-small btn-danger" {{on "click" (fn this.removeCar car.id)}}>
                🗑 Remove
              </button>
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="events-empty">
      <p>Your garage is empty! Add your first car to get started.</p>
    </div>
  {{/if}}
</div>
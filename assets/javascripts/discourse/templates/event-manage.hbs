<div class="event-manage-container">
  <div class="events-nav">
    <LinkTo @route="events" class="btn btn-default">📅 Events</LinkTo>
    <LinkTo @route="event" @model={{this.model.event.id}} class="btn btn-default">
      👁 View Event
    </LinkTo>
  </div>

  <div class="event-manage-header">
    <div>
      <h1>⚙️ {{this.model.event.title}}</h1>
      <span class="event-status event-status--{{this.model.event.status}}">
        {{this.model.event.status}}
      </span>
    </div>
    <div class="event-manage-actions">
      {{#if (eq this.model.event.status "draft")}}
        <button class="btn btn-warning" {{on "click" this.publishEvent}}>
          📢 Publish
        </button>
      {{/if}}
      {{#unless (eq this.model.event.status "cancelled")}}
        <button class="btn btn-danger" {{on "click" this.cancelEvent}}>
          ❌ Cancel Event
        </button>
      {{/unless}}
    </div>
  </div>

  {{!-- Tabs --}}
  <div class="manage-tabs">
    <button
      class="manage-tab {{if (eq this.activeTab 'details') 'active'}}"
      {{on "click" this.showDetails}}
    >
      📋 Details
    </button>
    <button
      class="manage-tab {{if (eq this.activeTab 'entrants') 'active'}}"
      {{on "click" this.showEntrants}}
    >
      🏎️ Entrants
    </button>
    <button
      class="manage-tab {{if (eq this.activeTab 'classes') 'active'}}"
      {{on "click" this.showClasses}}
    >
      🏁 Classes
    </button>
    <button
      class="manage-tab {{if (eq this.activeTab 'pricing') 'active'}}"
      {{on "click" this.showPricing}}
    >
      💷 Pricing & Discounts
    </button>
  </div>

  {{!-- Details Tab --}}
  {{#if (eq this.activeTab "details")}}
    <div class="manage-section">
      <div class="manage-section-header">
        <h2>Event Details</h2>
        <button class="btn btn-small btn-default" {{on "click" this.toggleEdit}}>
          {{if this.editMode "Cancel" "✏️ Edit"}}
        </button>
      </div>

      {{#if this.editMode}}
        <div class="org-form-field">
          <label>Title</label>
          <input type="text" value={{this.model.event.title}} {{on "input" (fn this.updateField "title")}} />
        </div>
        <div class="event-description-field org-form-field">
          <label>Description</label>
          <DEditor @value={{this.editDescription}} @processPreview={{false}} />
        </div>
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Start Date</label>
            <input type="datetime-local" value={{this.model.event.start_date}} {{on "change" (fn this.updateField "start_date")}} />
          </div>
          <div class="org-form-field">
            <label>End Date</label>
            <input type="datetime-local" value={{this.model.event.end_date}} {{on "change" (fn this.updateField "end_date")}} />
          </div>
        </div>
        <div class="org-form-field">
          <label>Booking Closing Date</label>
          <input type="datetime-local" value={{this.model.event.booking_closing_date}} {{on "change" (fn this.updateField "booking_closing_date")}} />
        </div>
        <div class="org-form-field">
          <label>Max Classes Per Booking</label>
          <input type="number" min="1" placeholder="Unlimited" value={{this.model.event.max_classes_per_booking}} {{on "input" (fn this.updateField "max_classes_per_booking")}} />
          <p class="field-help">Leave blank for unlimited.</p>
        </div>
        <div class="org-form-field">
          <label>Location</label>
          <input type="text" value={{this.model.event.location}} {{on "input" (fn this.updateField "location")}} />
        </div>
        <div class="org-form-field">
          <label>Google Maps URL</label>
          <input type="url" value={{this.model.event.google_maps_url}} {{on "input" (fn this.updateField "google_maps_url")}} />
        </div>
        <button
          class="btn btn-primary"
          disabled={{this.isSaving}}
          {{on "click" this.saveChanges}}
        >
          {{if this.isSaving "Saving..." "Save Changes"}}
        </button>
      {{else}}
        <div class="event-detail-list">
          <div class="event-detail-row">
            <span class="event-detail-label">📅 Start</span>
            <span>{{this.model.event.formatted_start_date}}</span>
          </div>
          {{#if this.model.event.location}}
            <div class="event-detail-row">
              <span class="event-detail-label">📍 Location</span>
              <span>{{this.model.event.location}}</span>
            </div>
          {{/if}}
          {{#if this.model.event.booking_closing_date}}
            <div class="event-detail-row">
              <span class="event-detail-label">⏰ Booking closes</span>
              <span>{{this.model.event.formatted_booking_closing_date}}</span>
            </div>
          {{/if}}
        </div>
      {{/if}}

      <div class="manage-classes">
        <h3>Classes</h3>
        {{#each this.model.event.classes as |cls|}}
          <div class="manage-class-row">
            <span class="manage-class-name">{{cls.name}}</span>
            <span class="manage-class-bookings">{{cls.bookings_count}} / {{cls.capacity}} booked</span>
            <span class="org-status org-status--{{cls.status}}">{{cls.status}}</span>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}

  {{!-- Classes Tab --}}
  {{#if (eq this.activeTab "classes")}}
    <div class="manage-section">
      <h2>Classes</h2>

      <table class="entrants-table">
        <thead>
          <tr>
            <th>Class Name</th>
            <th>Capacity</th>
            <th>Spaces Remaining</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.model.event.classes as |cls|}}
            <tr>
              <td>{{cls.name}}</td>
              <td>
                {{#if (eq this.editingClassId cls.id)}}
                  <input
                    type="number"
                    min="1"
                    value={{this.editingClassCapacity}}
                    {{on "input" this.updateEditingCapacity}}
                    class="inline-edit-input"
                  />
                {{else}}
                  {{cls.capacity}}
                {{/if}}
              </td>
              <td>{{cls.spaces_remaining}}</td>
              <td>
                <span class="org-status org-status--{{cls.status}}">{{cls.status}}</span>
              </td>
              <td>
                {{#if (eq this.editingClassId cls.id)}}
                  <button class="btn btn-small btn-primary" {{on "click" (fn this.saveClassCapacity cls)}}>
                    Save
                  </button>
                  <button class="btn btn-small btn-default" {{on "click" this.cancelEditClass}}>
                    Cancel
                  </button>
                {{else}}
                  <button class="btn btn-small btn-default" {{on "click" (fn this.startEditClass cls)}}>
                    Edit Capacity
                  </button>
                  {{#if (eq cls.status "inactive")}}
                    <button class="btn btn-small btn-primary" {{on "click" (fn this.toggleClassStatus cls)}}>
                      Reopen
                    </button>
                  {{else}}
                    <button class="btn btn-small btn-danger" {{on "click" (fn this.toggleClassStatus cls)}}>
                      Close
                    </button>
                  {{/if}}
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>

      <h3>Add Class</h3>
      {{#if this.classTypes}}
        <div class="org-form-row">
          <div class="org-form-field">
            <label>Class Type</label>
            <select {{on "change" this.updateNewClassTypeId}}>
              {{#each this.classTypes as |ct|}}
                <option value={{ct.id}} selected={{eq ct.id this.newClassTypeId}}>{{ct.name}}</option>
              {{/each}}
            </select>
          </div>
          <div class="org-form-field">
            <label>Capacity</label>
            <input
              type="number"
              min="1"
              placeholder="e.g. 20"
              value={{this.newClassCapacity}}
              {{on "input" this.updateNewClassCapacity}}
            />
          </div>
          <div class="org-form-field" style="align-self: flex-end;">
            <button class="btn btn-primary" {{on "click" this.addClass}}>
              Add Class
            </button>
          </div>
        </div>
      {{else}}
        <p class="field-help">Loading class types...</p>
      {{/if}}
    </div>
  {{/if}}

  {{!-- Entrants Tab --}}
  {{#if (eq this.activeTab "entrants")}}
    <div class="manage-section">
      <div class="manage-section-header">
        <h2>Entrants</h2>
        <button class="btn btn-default" {{on "click" this.downloadCsv}}>
          📥 Download RCTiming CSV
        </button>
      </div>

      <div class="entrants-filters">
        <button class="btn btn-small {{if (eq this.entrantsFilter 'all') 'btn-primary' 'btn-default'}}"
          {{on "click" (fn this.setEntrantsFilter "all")}}>
          All ({{this.entrantsStatusCounts.all}})
        </button>
        <button class="btn btn-small {{if (eq this.entrantsFilter 'confirmed') 'btn-primary' 'btn-default'}}"
          {{on "click" (fn this.setEntrantsFilter "confirmed")}}>
          ✅ Confirmed ({{this.entrantsStatusCounts.confirmed}})
        </button>
        <button class="btn btn-small {{if (eq this.entrantsFilter 'pending') 'btn-primary' 'btn-default'}}"
          {{on "click" (fn this.setEntrantsFilter "pending")}}>
          ⏳ Pending ({{this.entrantsStatusCounts.pending}})
        </button>
        <button class="btn btn-small {{if (eq this.entrantsFilter 'cancelled') 'btn-primary' 'btn-default'}}"
          {{on "click" (fn this.setEntrantsFilter "cancelled")}}>
          ❌ Cancelled ({{this.entrantsStatusCounts.cancelled}})
        </button>
        <button class="btn btn-small {{if (eq this.entrantsFilter 'waitlist') 'btn-primary' 'btn-default'}}"
          {{on "click" (fn this.setEntrantsFilter "waitlist")}}>
          📋 Waitlist ({{this.entrantsStatusCounts.waitlist}})
        </button>
      </div>

      {{#each this.filteredEntrantsClasses as |cls|}}
        <div class="entrants-class">
          <h3>
            {{cls.name}}
            <span class="field-help">{{cls.entrants.length}} / {{cls.capacity}} entries</span>
          </h3>
          {{#if cls.entrants.length}}
            <table class="entrants-table">
              <thead>
                <tr>
                  <th class="avatar-col"></th>
                  <th>Username</th>
                  <th>Manufacturer</th>
                  <th>Model</th>
                  <th>Transponder</th>
                  <th>BRCA No.</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each cls.entrants as |entrant|}}
                  <tr class="entrant-row entrant-row--{{entrant.status}}">
                    <td class="avatar-col"><a data-user-card={{entrant.username}}><img src="{{entrant.avatar_template}}" class="entrant-avatar" alt="" /></a></td>
                    <td>{{entrant.username}}</td>
                    <td>{{entrant.manufacturer_name}}</td>
                    <td>{{entrant.model_name}}</td>
                    <td class="transponder-number">{{entrant.transponder}}</td>
                    <td>{{entrant.brca_number}}</td>
                    <td>
                      <span class="booking-status booking-status--{{entrant.status}}">
                        {{entrant.status}}
                      </span>
                    </td>
                    <td class="entrant-actions">
                      {{#unless (eq entrant.status "cancelled")}}
                        <button
                          class="btn btn-small btn-danger"
                          {{on "click" (fn this.cancelEntrant entrant cls.name)}}
                        >
                          Cancel
                        </button>
                      {{/unless}}
                      {{#if this.currentUser.admin}}
                        <button
                          class="btn btn-small btn-danger"
                          {{on "click" (fn this.deleteBooking entrant cls.name)}}
                        >
                          🗑 Delete
                        </button>
                      {{/if}}
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{else}}
            <p class="field-help">No entrants matching filter.</p>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{/if}}


  {{!-- Pricing Tab --}}
  {{#if (eq this.activeTab "pricing")}}
    <div class="manage-section">
      <h2>Pricing & Discounts</h2>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>First Class Price (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.first_class_price}}
            {{on "input" (fn this.updatePricingForm "first_class_price")}} />
        </div>
        <div class="org-form-field">
          <label>Subsequent Classes (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.subsequent_class_price}}
            {{on "input" (fn this.updatePricingForm "subsequent_class_price")}} />
        </div>
      </div>
      <h3>Member Discounts</h3>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>Member - 1st Class Discount (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.member_first_class_discount}}
            {{on "input" (fn this.updatePricingForm "member_first_class_discount")}} />
        </div>
        <div class="org-form-field">
          <label>Member - Subsequent Classes (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.member_subsequent_discount}}
            {{on "input" (fn this.updatePricingForm "member_subsequent_discount")}} />
        </div>
      </div>
      <h3>Junior Discounts (Under 16)</h3>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>Junior - 1st Class Discount (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.junior_first_class_discount}}
            {{on "input" (fn this.updatePricingForm "junior_first_class_discount")}} />
        </div>
        <div class="org-form-field">
          <label>Junior - Subsequent Classes (£)</label>
          <input type="number" min="0" step="0.50"
            value={{this.pricingForm.junior_subsequent_discount}}
            {{on "input" (fn this.updatePricingForm "junior_subsequent_discount")}} />
        </div>
      </div>
      <button class="btn btn-primary" {{on "click" this.savePricing}}>
        💾 Save Pricing
      </button>
    </div>
  {{/if}}

</div>
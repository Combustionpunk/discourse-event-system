<div class="venue-detail-container">
  <div class="events-nav">
    <LinkTo @route="venues" class="btn btn-default">📍 All Venues</LinkTo>
  </div>

  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
    {{#if this.model.venue.can_edit}}
      <button class="btn btn-default btn-small" {{on "click" this.toggleEdit}}>{{if this.editMode "Cancel" "✏️ Edit Venue"}}</button>
    {{/if}}
    {{#if this.currentUser}}
      {{#unless this.model.venue.can_edit}}
        <button class="btn btn-default btn-small" {{on "click" this.toggleSuggest}}>{{if this.suggestMode "Cancel" "💡 Suggest Edit"}}</button>
      {{/unless}}
      {{#if this.canClaim}}
        <button class="btn btn-default btn-small" {{on "click" this.claimVenue}}>🏠 Claim this Venue</button>
      {{/if}}
    {{/if}}
  </div>

  {{#if this.claimSent}}
    <div style="background:var(--success-low);border:1px solid var(--success);border-radius:6px;padding:10px 14px;margin:12px 0;color:var(--success);">
      ✅ Claim submitted! An admin will review it shortly.
    </div>
  {{/if}}

  {{#if (eq this.model.venue.claim_status "pending")}}
    <div style="background:var(--highlight-low);padding:8px 12px;border-radius:6px;margin:8px 0;">
      ⏳ Claim pending approval
    </div>
  {{/if}}

  {{#if (eq this.model.venue.claim_status "approved")}}
    <div style="margin:8px 0;">
      🏠 Home venue of <strong>{{this.model.venue.claimed_organisation_name}}</strong>
    </div>
  {{/if}}

  {{#if this.model.venue.is_stub}}
    <div class="venue-stub-banner" style="background:var(--highlight-low);border:1px solid var(--highlight);border-radius:6px;padding:10px 14px;margin:12px 0;color:var(--highlight-high);">
      📍 This venue was automatically imported from BRCA data and may be incomplete.
      Help the community by filling in the details below!
    </div>
  {{/if}}

  {{#if this.suggestionSent}}
    <div style="background:var(--success-low);border:1px solid var(--success);border-radius:6px;padding:10px 14px;margin:12px 0;color:var(--success);">
      ✅ Thank you! Your suggestion has been submitted for review.
    </div>
  {{/if}}

  <h1>{{this.model.venue.name}}</h1>

  {{#if this.editMode}}
    <div class="venue-form event-form-section">
      <DesVenueForm
        @venue={{this.editData}}
        @onSave={{this.saveVenue}}
        @onCancel={{this.toggleEdit}}
        @saveLabel="💾 Save Changes"
      />
    </div>
  {{/if}}

  {{#if this.suggestMode}}
    <div class="venue-form event-form-section">
      <DesVenueForm
        @venue={{this.suggestData}}
        @onSave={{this.submitSuggestion}}
        @onCancel={{this.toggleSuggest}}
        @saveLabel="💡 Submit Suggestion"
      />
    </div>
  {{/if}}


  <div class="venue-detail-meta">
    {{#if this.model.venue.address}}
      <div class="venue-detail-item">📍 {{this.model.venue.address}}</div>
    {{/if}}
    {{#if this.model.venue.google_maps_url}}
      <div class="venue-detail-item">
        <a href={{this.model.venue.google_maps_url}} target="_blank" rel="noopener">🗺️ View on Google Maps</a>
      </div>
    {{/if}}
    {{#if this.model.venue.website}}
      <div class="venue-detail-item">
        <a href={{this.model.venue.website}} target="_blank" rel="noopener">🌐 Website</a>
      </div>
    {{/if}}
    {{#if this.model.venue.organisation_name}}
      <div class="venue-detail-item">🏢 {{this.model.venue.organisation_name}}</div>
    {{/if}}
  </div>

  {{#if this.model.venue.tracks.length}}
    <div class="venue-tracks">
      <h3>🏁 Tracks</h3>
      {{#each this.model.venue.tracks as |track|}}
        <div class="venue-track">
          {{#if track.name}}<span class="venue-track-name">🏁 {{track.name}}</span>{{/if}}
          {{#if track.surface}}<span class="rc-event-badge rc-surface-badge">{{track.surface}}</span>{{/if}}
          {{#if track.environment}}<span class="rc-event-badge rc-environment-badge">{{track.environment}}</span>{{/if}}
          {{#if track.description}}<p class="venue-track-description">{{track.description}}</p>{{/if}}
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if this.model.venue.description}}
    <div class="event-description-box">{{this.model.venue.description}}</div>
  {{/if}}

  <div class="venue-facilities">
    <h3>Facilities</h3>
    <div class="venue-facilities-grid">
      <div class="facility-item {{if this.model.venue.has_permanent_toilets 'facility--yes' 'facility--no'}}">🚻 Permanent Toilets</div>
      <div class="facility-item {{if this.model.venue.has_portaloos 'facility--yes' 'facility--no'}}">🚽 Portaloos</div>
      <div class="facility-item {{if this.model.venue.has_bar 'facility--yes' 'facility--no'}}">🍺 Bar</div>
      <div class="facility-item {{if this.model.venue.has_cafe 'facility--yes' 'facility--no'}}">☕ Café</div>
      <div class="facility-item {{if this.model.venue.has_showers 'facility--yes' 'facility--no'}}">🚿 Showers</div>
      <div class="facility-item {{if this.model.venue.has_power_supply 'facility--yes' 'facility--no'}}">⚡ Power Supply</div>
      <div class="facility-item {{if this.model.venue.has_water_supply 'facility--yes' 'facility--no'}}">💧 Water Supply</div>
      <div class="facility-item {{if this.model.venue.has_camping 'facility--yes' 'facility--no'}}">⛺ Camping</div>
      <div class="facility-item {{if this.model.venue.has_track_shop 'facility--yes' 'facility--no'}}">🛒 Track Shop</div>
    </div>
  </div>

  {{#if this.model.venue.parking_info}}
    <div class="venue-info-section">
      <h3>🅿️ Parking</h3>
      <p>{{this.model.venue.parking_info}}</p>
    </div>
  {{/if}}

  {{#if this.model.venue.access_notes}}
    <div class="venue-info-section">
      <h3>ℹ️ Access Notes</h3>
      <p>{{this.model.venue.access_notes}}</p>
    </div>
  {{/if}}

  {{#if this.model.upcoming_events.length}}
    <div class="venue-events">
      <h3>📅 Upcoming Events</h3>
      {{#each this.model.upcoming_events as |event|}}
        <div class="venue-event-item">
          {{#if (eq event.type "imported")}}
            <a href={{event.booking_url}} target="_blank" rel="noopener">{{event.title}}</a>
            <span class="rc-event-badge rc-event-badge--brca">BRCA</span>
          {{else}}
            <LinkTo @route="event" @model={{event.id}}>{{event.title}}</LinkTo>
          {{/if}}
          <span class="venue-event-date">📅 {{event.formatted_date}}</span>
          <span class="field-help">{{event.organisation_name}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}
</div>

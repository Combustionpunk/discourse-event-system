<div class="family-setup-container">
  <div class="events-nav">
    <LinkTo @route="my-memberships" class="btn btn-default">🎫 My Memberships</LinkTo>
  </div>

  {{#if this.model.error}}
    <div class="booking-error">
      <div class="booking-success-icon">❌</div>
      <h1>Error</h1>
      <p>{{this.model.error}}</p>
    </div>
  {{else if this.completed}}
    <div class="booking-success">
      <div class="booking-success-icon">🎉</div>
      <h1>Family Membership Set Up!</h1>
      <p>Your family membership for <strong>{{this.model.organisation_name}}</strong> is ready.</p>

      {{#if this.createdAccounts.length}}
        <div class="created-accounts-summary">
          <h3>📋 New Account Login Details</h3>
          <p class="field-help">Please save these details — the passwords cannot be retrieved later.</p>
          <table class="family-accounts-table">
            <thead>
              <tr>
                <th>Username</th>
                <th>Password</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.createdAccounts as |account|}}
                <tr>
                  <td><strong>{{account.username}}</strong></td>
                  <td><code>{{account.password}}</code></td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/if}}

      {{#if this.familyMembers.length}}
        <div class="family-summary-table">
          <h3>👨‍👩‍👧 Family Members</h3>
          <table class="family-accounts-table">
            <thead>
              <tr>
                <th>Username</th>
                <th>Name</th>
                <th>Date of Birth</th>
                <th>BRCA Number</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.familyMembers as |member|}}
                <tr>
                  <td>{{member.username}}</td>
                  <td>{{member.name}}</td>
                  <td>{{member.date_of_birth}}</td>
                  <td>{{member.brca_membership_number}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/if}}

      <div class="booking-success-actions">
        <button type="button" class="btn btn-primary" {{on "click" this.goToMemberships}}>
          🎫 Go to My Memberships
        </button>
      </div>
    </div>
  {{else}}
    <h1>👨‍👩‍👧 Set Up Family Members</h1>
    <p>Your family membership for <strong>{{this.model.organisation_name}}</strong> allows up to <strong>{{this.model.max_members}}</strong> members (including you).</p>
    <p class="field-help">Add up to {{this.availableSlots}} additional family members below. You can search for existing users or create new accounts.</p>

    {{#if this.errorMessage}}
      <div class="alert alert-error family-error">{{this.errorMessage}}</div>
    {{/if}}

    {{#if this.familyMembers.length}}
      <div class="family-current-members">
        <h3>Current Family Members</h3>
        {{#each this.familyMembers as |member|}}
          <div class="family-member-row">
            <div class="family-member-info">
              {{#if member.avatar_url}}
                <img src="{{member.avatar_url}}" class="user-avatar" alt="" />
              {{/if}}
              <span class="user-username">{{member.username}}</span>
              {{#if member.name}}<span class="user-name">— {{member.name}}</span>{{/if}}
              {{#if member.date_of_birth}}<span class="member-detail">DOB: {{member.date_of_birth}}</span>{{/if}}
              {{#if member.brca_membership_number}}<span class="member-detail">BRCA: {{member.brca_membership_number}}</span>{{/if}}
            </div>
            <button type="button" class="btn btn-small btn-danger" {{on "click" (fn this.removeMember member)}}>Remove</button>
          </div>
        {{/each}}
      </div>
    {{/if}}

    {{#if this.canAddMore}}
      <div class="family-add-section">
        <h3>Add Family Member</h3>

        <div class="family-search-box">
          <label>Search for existing user:</label>
          <input
            type="text"
            placeholder="Type username or name to search..."
            class="family-search-input"
            value={{this.searchTerm}}
            {{on "input" this.onSearchInput}}
          />
        </div>

        {{#if this.searchResults.length}}
          <div class="family-search-results">
            {{#each this.searchResults as |user|}}
              <div class="family-search-result" role="button" {{on "click" (fn this.selectExistingUser user)}}>
                {{#if user.avatar_template}}
                  <img src="{{user.avatar_template}}" class="user-avatar" alt="" />
                {{/if}}
                <span class="user-username">{{user.username}}</span>
                {{#if user.name}}<span class="user-name">— {{user.name}}</span>{{/if}}
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if this.addingMember}}
          <div class="family-loading">Adding member...</div>
        {{/if}}

        <div class="family-or-divider">
          <span>— OR —</span>
        </div>

        <button type="button" class="btn btn-default" {{on "click" this.toggleCreateForm}}>
          {{#if this.showCreateForm}}Hide Create Form{{else}}➕ Create New Account{{/if}}
        </button>

        {{#if this.showCreateForm}}
          <div class="family-create-form">
            <div class="family-form-field">
              <label>Username <span class="required">*</span></label>
              <input type="text" value={{this.newUsername}} {{on "input" this.setNewUsername}} placeholder="username" />
            </div>
            <div class="family-form-field">
              <label>Full Name <span class="required">*</span></label>
              <input type="text" value={{this.newName}} {{on "input" this.setNewName}} placeholder="Full Name" />
            </div>
            <div class="family-form-field">
              <label>Date of Birth <span class="required">*</span></label>
              <input type="date" value={{this.newDob}} {{on "input" this.setNewDob}} />
            </div>
            <div class="family-form-field">
              <label>BRCA Number</label>
              <input type="text" value={{this.newBrca}} {{on "input" this.setNewBrca}} placeholder="Optional" />
            </div>
            <div class="family-form-field">
              <label>Email</label>
              <input type="email" value={{this.newEmail}} {{on "input" this.setNewEmail}} placeholder="Optional — auto-generated if blank" />
            </div>
            <button type="button" class="btn btn-primary" {{on "click" this.createAndAddUser}}
              disabled={{this.creatingUser}}>
              {{#if this.creatingUser}}Creating...{{else}}Create & Add Member{{/if}}
            </button>
          </div>
        {{/if}}
      </div>
    {{/if}}

    <div class="family-setup-actions">
      <button type="button" class="btn btn-primary btn-large" {{on "click" this.finishSetup}}>
        ✅ Done — View Summary
      </button>
    </div>
  {{/if}}
</div>

<div class="events-container">
  <div class="events-nav">
    <LinkTo @route="my-organisations" class="btn btn-default">🏢 My Organisations</LinkTo>
    <LinkTo @route="racing-profile" class="btn btn-default">🏎️ My Racing Profile</LinkTo>
    <LinkTo @route="my-garage" class="btn btn-default">🚗 My Garage</LinkTo>
    <LinkTo @route="my-bookings" class="btn btn-default">🎟️ My Bookings</LinkTo>
    <LinkTo @route="my-memberships" class="btn btn-default">🎫 My Memberships</LinkTo>
  </div>

  <div class="events-header">
    <h1>{{if this.isUpcoming "Upcoming Events" "Past Events"}}</h1>
    {{#if this.currentUser.staff}}
      <LinkTo @route="event-new" class="btn btn-primary">+ Create Event</LinkTo>
    {{/if}}
  </div>

  {{!-- Filters --}}
  <div class="events-filters">
    <div class="events-filter-tabs">
      <button
        class="btn {{if this.isUpcoming 'btn-primary' 'btn-default'}}"
        {{on "click" (fn this.setFilter "upcoming")}}
      >
        📅 Upcoming
      </button>
      <button
        class="btn {{unless this.isUpcoming 'btn-primary' 'btn-default'}}"
        {{on "click" (fn this.setFilter "past")}}
      >
        🕐 Past
      </button>
    </div>
    <div class="events-filter-selects">
      <select {{on "change" this.setOrganisation}}>
        <option value="">All Organisations</option>
        {{#each this.model.organisations as |org|}}
          <option value={{org.id}} selected={{eq (concat org.id "") this.organisation_id}}>{{org.name}}</option>
        {{/each}}
      </select>
      <select {{on "change" this.setEventType}}>
        <option value="">All Event Types</option>
        {{#each this.model.event_types as |et|}}
          <option value={{et.id}} selected={{eq (concat et.id "") this.event_type_id}}>{{et.name}}</option>
        {{/each}}
      </select>
    </div>
  </div>


  {{#if this.model.events.length}}
    <div class="events-list">
      {{#each this.model.events as |event|}}
        <div class="event-card">
          <div class="event-card-header">
            <h2 class="event-title">
              <LinkTo @route="event" @model={{event.id}}>
                {{event.title}}
              </LinkTo>
            </h2>
            <span class="event-status event-status--{{event.status}}">
              {{event.status}}
            </span>
          </div>

          <div class="event-meta">
            <span class="event-organisation">
              {{#if event.organisation.logo_url}}<img src={{event.organisation.logo_url}} class="org-logo org-logo--inline" alt="" />{{/if}} {{event.organisation.name}}
            </span>
            {{#if event.venue}}
              <span class="event-venue-inline">
                📍 {{event.venue.name}}
                {{#if event.venue.track_environment}}<span class="venue-badge venue-badge--environment venue-badge--small">{{#if (eq event.venue.track_environment "outdoor")}}🌳{{else}}🏠{{/if}}</span>{{/if}}
                {{#if event.venue.track_category}}<span class="venue-badge venue-badge--category venue-badge--small">{{#if (eq event.venue.track_category "onroad")}}🛣️{{else}}🌿{{/if}}</span>{{/if}}
                {{#if event.venue.track_surface}}<span class="venue-badge venue-badge--surface venue-badge--small">{{event.venue.track_surface}}</span>{{/if}}
              </span>
            {{/if}}
            <span class="event-date">
              📅 {{event.formatted_date}}
            </span>
            {{#if event.location}}
              <span class="event-location">
                📍 {{event.location}}
              </span>
            {{/if}}
          </div>

          <div class="event-classes">
            {{#each event.classes as |cls|}}
              <span class="event-class-badge">
                {{cls.name}} ({{cls.spaces_remaining}} spaces)
              </span>
            {{/each}}
          </div>

          <div class="event-footer">
            {{#if event.pricing}}
              <span class="event-price">
                💷 From £{{event.pricing.first_class_price}}
              </span>
            {{/if}}
            <LinkTo @route="event" @model={{event.id}} class="btn btn-primary">
              View Event
            </LinkTo>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="events-empty">
      <p>No {{if this.isUpcoming "upcoming" "past"}} events found.</p>
    </div>
  {{/if}}
</div>

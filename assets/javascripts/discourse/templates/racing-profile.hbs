<div class="racing-profile-container">
  <div class="events-nav">
    <LinkTo @route="my-organisations" class="btn btn-default">🏢 My Organisations</LinkTo>
    <LinkTo @route="racing-profile" class="btn btn-default">🏎️ My Racing Profile</LinkTo>
    <LinkTo @route="my-garage" class="btn btn-default">🚗 My Garage</LinkTo>
    <LinkTo @route="my-bookings" class="btn btn-default">🎟️ My Bookings</LinkTo>
    <LinkTo @route="my-memberships" class="btn btn-default">🎫 My Memberships</LinkTo>
  </div>

  <h1>🏎️ My Racing Profile</h1>

  <div class="profile-section">
    <h2>Personal Details</h2>

    <div class="org-form-field">
      <label>Date of Birth</label>
      <p class="field-help">Used to calculate eligibility for age-based discounts (e.g. junior pricing)</p>
      <input
        type="date"
        value={{this.model.profile.user.date_of_birth}}
        {{on "change" this.setDateOfBirth}}
      />
    </div>

    <div class="org-form-field" style="margin-top: 16px;">
      <label>BRCA Membership Number</label>
      <p class="field-help">Required after your first 3 bookings</p>
      <input
        type="text"
        placeholder="e.g. 221708"
        value={{this.model.profile.user.brca_membership_number}}
        {{on "input" this.setBrcaNumber}}
      />
    </div>

    <div class="org-form-row" style="margin-top: 16px;">
      <div class="org-form-field">
        <label>F Grade (Formula)</label>
        <select {{on "change" this.setFGrade}}>
          <option value="0" selected={{eq this.model.profile.user.f_grade "0"}}>0</option>
          <option value="1" selected={{eq this.model.profile.user.f_grade "1"}}>1</option>
          <option value="2" selected={{eq this.model.profile.user.f_grade "2"}}>2</option>
          <option value="3" selected={{eq this.model.profile.user.f_grade "3"}}>3</option>
          <option value="4" selected={{eq this.model.profile.user.f_grade "4"}}>4</option>
          <option value="5" selected={{eq this.model.profile.user.f_grade "5"}}>5</option>
        </select>
      </div>
      <div class="org-form-field">
        <label>T Grade (Truck Grade)</label>
        <select {{on "change" this.setTGrade}}>
          <option value="0" selected={{eq this.model.profile.user.t_grade "0"}}>0</option>
          <option value="1" selected={{eq this.model.profile.user.t_grade "1"}}>1</option>
          <option value="2" selected={{eq this.model.profile.user.t_grade "2"}}>2</option>
          <option value="3" selected={{eq this.model.profile.user.t_grade "3"}}>3</option>
          <option value="4" selected={{eq this.model.profile.user.t_grade "4"}}>4</option>
          <option value="5" selected={{eq this.model.profile.user.t_grade "5"}}>5</option>
        </select>
      </div>
    </div>


    <button class="btn btn-primary" style="margin-top: 16px;" {{on "click" this.saveProfile}}>
      Save Details
    </button>
  </div>


  {{!-- Transponder Registry --}}
  <div class="profile-section" style="margin-top: 24px;">
    <h2>📡 My Transponders</h2>
    <p class="field-help">Your transponder registry. Use shortcodes when entering transponders on your cars.</p>

    {{#if this.transponders.length}}
      <div class="transponder-list">
        {{#each this.transponders as |t|}}
          <div class="admin-org-card">
            {{#if (eq this.editingTransponderId t.id)}}
              <div class="org-form-row">
                <div class="org-form-field">
                  <label>Long Code</label>
                  <input type="text" value={{this.editTransponderCode}} {{on "input" this.updateEditTransponderCode}} />
                </div>
                <div class="org-form-field">
                  <label>Notes</label>
                  <input type="text" value={{this.editTransponderNotes}} placeholder="e.g. blue one" {{on "input" this.updateEditTransponderNotes}} />
                </div>
              </div>
              <div class="admin-org-actions">
                <button class="btn btn-primary btn-small" {{on "click" (fn this.saveTransponder t)}}>💾 Save</button>
                <button class="btn btn-default btn-small" {{on "click" this.cancelEditTransponder}}>✕ Cancel</button>
              </div>
            {{else}}
              <div class="admin-org-info">
                <strong>#{{t.shortcode}} — {{t.long_code}}</strong>
                {{#if t.notes}}<span class="field-help"> ({{t.notes}})</span>{{/if}}
              </div>
              <div class="admin-org-actions">
                <button class="btn btn-default btn-small" {{on "click" (fn this.startEditTransponder t)}}>✏️ Edit</button>
                <button class="btn btn-danger btn-small" {{on "click" (fn this.deleteTransponder t)}}>🗑 Delete</button>
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="field-help">No transponders registered yet.</p>
    {{/if}}

    <div class="transponder-add-form" style="margin-top: 16px;">
      <h3>Add Transponder</h3>
      <div class="org-form-row">
        <div class="org-form-field">
          <label>Long Code *</label>
          <input type="text" placeholder="e.g. 7456985" value={{this.newTransponderCode}} {{on "input" this.updateNewTransponderCode}} />
        </div>
        <div class="org-form-field">
          <label>Notes</label>
          <input type="text" placeholder="e.g. blue one" value={{this.newTransponderNotes}} {{on "input" this.updateNewTransponderNotes}} />
        </div>
        <div class="org-form-field" style="justify-content: flex-end;">
          <button class="btn btn-primary" {{on "click" this.addTransponder}}>➕ Add Transponder</button>
        </div>
      </div>
    </div>
  </div>

  {{!-- My Parent/Guardian Section --}}
  <div class="profile-section" style="margin-top: 24px;">
    <h2>🛡️ My Parent/Guardian</h2>
    <p class="field-help">Set your parent or guardian so they can book events on your behalf.</p>

    {{#if this.guardianError}}
      <div class="alert alert-error family-error">{{this.guardianError}}</div>
    {{/if}}

    {{#if this.myGuardian}}
      <div class="family-member-row">
        <div class="family-member-info">
          {{#if this.myGuardian.avatar_url}}
            <img src="{{this.myGuardian.avatar_url}}" class="user-avatar" alt="" />
          {{/if}}
          <span class="user-username">{{this.myGuardian.username}}</span>
          {{#if this.myGuardian.name}}<span class="user-name">— {{this.myGuardian.name}}</span>{{/if}}
        </div>
        <div class="family-member-actions">
          <button class="btn btn-small btn-danger" {{on "click" this.removeGuardian}}>Remove</button>
        </div>
      </div>
    {{else}}
      <div class="family-search-box">
        <label>Search for your parent/guardian:</label>
        <input
          type="text"
          placeholder="Type their username..."
          class="family-search-input"
          {{on "input" this.searchGuardian}}
        />
      </div>
      {{#if this.guardianSearchResults.length}}
        <div class="family-search-results">
          {{#each this.guardianSearchResults as |user|}}
            <div class="family-search-result" role="button" {{on "click" (fn this.selectGuardian user)}}>
              {{#if user.avatar_template}}
                <img src="{{user.avatar_template}}" class="user-avatar" alt="" />
              {{/if}}
              <span class="user-username">{{user.username}}</span>
              {{#if user.name}}<span class="user-name">— {{user.name}}</span>{{/if}}
            </div>
          {{/each}}
        </div>
      {{/if}}
    {{/if}}
  </div>

  {{!-- Family Members Section --}}
  <div class="profile-section" style="margin-top: 24px;">
    <h2>👨‍👩‍👧 My Dependants</h2>
    <p class="field-help">Users you are guardian of. You can book events on their behalf.</p>

    {{#if this.familyError}}
      <div class="alert alert-error family-error">{{this.familyError}}</div>
    {{/if}}

    {{#if this.createdFamilyAccounts.length}}
      <div class="created-accounts-summary">
        <h3>📋 New Account Login Details</h3>
        <p class="field-help">Please save these — passwords cannot be retrieved later.</p>
        <table class="family-accounts-table">
          <thead><tr><th>Username</th><th>Password</th></tr></thead>
          <tbody>
            {{#each this.createdFamilyAccounts as |account|}}
              <tr>
                <td><strong>{{account.username}}</strong></td>
                <td><code>{{account.password}}</code></td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{#if this.familyMembers.length}}
      <div class="family-current-members">
        {{#each this.familyMembers as |member|}}
          <div class="family-member-row">
            {{#if (eq this.editingFamilyId member.user_id)}}
              <div class="family-member-edit" style="width:100%;">
                <strong>{{member.username}}</strong>
                <div class="org-form-row" style="margin-top:8px;">
                  <div class="org-form-field">
                    <label>Date of Birth</label>
                    <input type="date" value={{this.editFamDob}} {{on "input" this.setEditFamDob}} />
                  </div>
                  <div class="org-form-field">
                    <label>BRCA Number</label>
                    <input type="text" value={{this.editFamBrca}} {{on "input" this.setEditFamBrca}} placeholder="Optional" />
                  </div>
                </div>
                <div style="display:flex;gap:6px;margin-top:8px;">
                  <button class="btn btn-small btn-primary" {{on "click" (fn this.saveEditFamily member)}}>Save</button>
                  <button class="btn btn-small btn-default" {{on "click" this.cancelEditFamily}}>Cancel</button>
                </div>
              </div>
            {{else}}
              <div class="family-member-info">
                {{#if member.avatar_url}}
                  <img src="{{member.avatar_url}}" class="user-avatar" alt="" />
                {{/if}}
                <span class="user-username">{{member.username}}</span>
                {{#if member.name}}<span class="user-name">— {{member.name}}</span>{{/if}}
                {{#if member.date_of_birth}}<span class="member-detail">DOB: {{member.date_of_birth}}</span>{{/if}}
                {{#if member.brca_membership_number}}<span class="member-detail">BRCA: {{member.brca_membership_number}}</span>{{/if}}
              </div>
              <div class="family-member-actions">
                <button class="btn btn-small btn-default" {{on "click" (fn this.startEditFamily member)}}>Edit</button>
                <button class="btn btn-small btn-danger" {{on "click" (fn this.removeFamilyMember member)}}>Remove</button>
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}

    <div class="family-add-section" style="margin-top:16px;">
      <h3>Add Dependant</h3>
      <p class="field-help">If your dependant does not already have an account, you can create one for them here.</p>

      <div class="family-create-form">
        <div class="family-form-field">
          <label>Username <span class="required">*</span></label>
          <input type="text" value={{this.newFamUsername}} {{on "input" this.setNewFamUsername}} placeholder="username" />
        </div>
        <div class="family-form-field">
          <label>Full Name <span class="required">*</span></label>
          <input type="text" value={{this.newFamName}} {{on "input" this.setNewFamName}} placeholder="Full Name" />
        </div>
        <div class="family-form-field">
          <label>Date of Birth <span class="required">*</span></label>
          <input type="date" value={{this.newFamDob}} {{on "input" this.setNewFamDob}} />
        </div>
        <div class="family-form-field">
          <label>BRCA Number</label>
          <input type="text" value={{this.newFamBrca}} {{on "input" this.setNewFamBrca}} placeholder="Optional" />
        </div>
        <div class="family-form-field">
          <label>Email</label>
          <input type="email" value={{this.newFamEmail}} {{on "input" this.setNewFamEmail}} placeholder="Optional — auto-generated if blank" />
        </div>
        <button class="btn btn-primary" {{on "click" this.createFamilyUser}} disabled={{this.familyCreating}}>
          {{if this.familyCreating "Creating..." "Create & Add Dependant"}}
        </button>
      </div>
    </div>
  </div>
</div>
